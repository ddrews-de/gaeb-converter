                            <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:bold;font-style:normal">Vorhaltung, Gerüstbekleidung, Schutznetz</span>
                          </p>
                        </TextOutlTxt>
                      </OutlTxt>
                    </OutlineText>
                  </CompleteText>
                </Description>
              </Item>
              <Item ID="_90ff74d5-d574-4eb9-9028-b399b897146d" RNoPart="160">
