              <Item ID="_4694454b-c294-4028-8fd8-66542b7e762e" RNoPart="180">
                <LumpSumItem>Yes</LumpSumItem>
                <Qty>1.000</Qty>
                <QU>psch</QU>
                <Description>
                  <CompleteText>
                    <DetailTxt>
                      <Text>
                        <p>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Planen und Erstellen einer prüffähigen Gerüststatik, einschl. Ausführungszeichnungen. Berechnung und Pläne sind spätestens 2 Wochen vor Beginn der Gerüstarbeiten der Bauleitung in 2 -facher Ausfertigung zu übergeben.</span>
                        </p>
                        <p/>
                      </Text>
                    </DetailTxt>
                    <OutlineText>
                      <OutlTxt>
                        <TextOutlTxt>
