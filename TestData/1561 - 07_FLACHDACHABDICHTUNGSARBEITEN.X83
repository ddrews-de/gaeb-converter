              </Item>
              <Item ID="_f01fd32a-956d-4164-872e-8cdc933b3a29" RNoPart="20">
                <Qty>1.000</Qty>
                <QU>h</QU>
                <Description>
                  <CompleteText>
                    <DetailTxt>
                      <Text>
                        <p>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Stundenverechnungslohn für Aufsichtspersonen</span>
                        </p>
                      </Text>
                    </DetailTxt>
                    <OutlineText>
                      <OutlTxt>
