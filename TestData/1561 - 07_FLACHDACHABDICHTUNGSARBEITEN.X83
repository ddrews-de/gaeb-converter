        <BoQCtgy ID="_24d92f1e-bffb-49d0-bc10-d5185f5a29ef" RNoPart="1">
          <LblTx>
            <p style="font-family:Arial;font-style:normal;font-weight:bold;font-size:10pt;color:rgb(0,0,0)">
              <span>Rückbauarbeiten, Provisorien, Verwertung</span>
            </p>
          </LblTx>
          <BoQBody>
            <Itemlist>
              <Item ID="_19df5bf3-d5e7-4380-80ce-eb9df2fd74a7" RNoPart="10">
                <Qty>122.000</Qty>
                <QU>m²</QU>
                <Description>
                  <CompleteText>
                    <DetailTxt>
                      <Text>
                        <p>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">des bestehenden Flachdachaufbaus, Baujahr 2015, in selektiver Rückbauweise bis Unterkante Dampfsperre, inkl. Rückbau der Notabläufe, Dacheinläufe, Entlüftungsrohre u. dgl. auch wenn diese nicht separat in dieser Pos. aufgeführt sind.</span>
                          <br/>
                        </p>
                        <p>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Lage		Flachdach Bestand = Dachgeschoß</span>
                        </p>
                        <p/>
                        <p>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Konstruktion	</span>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Dampfsperre, BauderTEC KSA Duo u. / o . Icopal Villatherm</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">		restliche Dampfsperre senkrecht</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">		</span>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Gefälledämmung EPS 035, zweilagig, mittlere Dicke ca. 162 mm</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">		</span>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Bitumenabdichtungen, 2-lagig, wohl Icopla Polar SK und Eco-activ Therm</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">		ca. 7 Stück Einbauteile bis DN 150</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">		provisorische Attikaabdichtung innen</span>
                          <br/>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Anschlusslänge	ca. 48 lfm, Höhe ca. 25 cm</span>
                        </p>
                        <p>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">aufgehende</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Bauteile	</span>
                          <br/>
                        </p>
                        <p>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Die Rückbauarbeiten sind nach Fläche anzubieten inkl. Separierung, Fraktionierung und Zerkleinerung oder Bereitstellung zur Entsorgung der einzelnen Materialien. Die hierfür erforderlichen Hilfsmittel und Geräte sind mit dem EP abgegolten.</span>
                          <br/>
                        </p>
                        <p>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Abrechnung nach m² Rohdachfläche</span>
                          <br/>
                        </p>
                      </Text>
                    </DetailTxt>
                    <OutlineText>
                      <OutlTxt>
                        <TextOutlTxt>
                          <p style="font-family:Arial;font-style:normal;font-weight:bold;font-size:10pt;color:rgb(0,0,0)">
                            <span>Rückbau Dachabdichtung</span>
                          </p>
                        </TextOutlTxt>
                      </OutlTxt>
                    </OutlineText>
                  </CompleteText>
                </Description>
              </Item>
