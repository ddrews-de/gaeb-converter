                                <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:bold;font-style:normal">Dampfsperre an aufgehenden Bauteilen</span>
                              </p>
                            </TextOutlTxt>
                          </OutlTxt>
                        </OutlineText>
                      </CompleteText>
                    </Description>
                  </Item>
                  <Item ID="_8d49646f-ad7b-44c4-80a2-418e55c9499a" RNoPart="60">
                    <Qty>8.000</Qty>
                    <QU>St</QU>
                    <Description>
                      <CompleteText>
                        <DetailTxt>
                          <Text>
                            <p>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Zulage zur Vorposition für das fach- und normgerechte Ausbilden der Ecken, als Innen- und Außenecken, fachgerecht herstellen, einschl. erforderlicher Formteile.</span>
                              <br/>
