                      </CompleteText>
                    </Description>
                  </Item>
                  <Item ID="_7280f4c1-318f-4190-bcfa-e6e801e68224" RNoPart="70">
                    <LumpSumItem>Yes</LumpSumItem>
                    <Qty>1.000</Qty>
                    <QU>psch</QU>
                    <Description>
                      <CompleteText>
                        <DetailTxt>
                          <Text>
                            <p>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Erstellen einer prüffähigen objektbezogenen Windsogberechung des gesamten Dachaufbaus und Übergabe in 2-facher Ausfertigung an den Bauherren.</span>
                            </p>
