          <BoQBody>
            <Itemlist>
              <Item ID="_d03eb613-eaa2-4fbc-a0e1-b4a2d15945fe" RNoPart="10">
                <LumpSumItem>Yes</LumpSumItem>
                <Qty>1.000</Qty>
                <QU>psch</QU>
                <Description>
                  <CompleteText>
                    <DetailTxt>
                      <Text>
                        <p>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Gaupenbacke der Position 1.20 an neu aufgehende Betonwand fachgerecht verlängern, dämmen und anschließen, einschließlich aller Befestigungsmittel und nachstehender Beschreibung anarbeiten.</span>
                          <br/>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">bestehend aus:</span>
                          <br/>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Aufbau		ca. 240 mm, Steinwolle 035, A1, zwischen</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">		Wand und Gaupenbacke, ca. 4 m²</span>
                          <br/>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">		über der neuen Wand WäDä s.o. mit Aufrippung</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">		aus Kanthölzer aus KVH</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">		Dampfbremse, schwarz</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">		Unterkonstruktion ca. 50/30 mm</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">		Lüftungswinkel, Kunststoff, schwarz</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">		HPL - Platten aus Rückbau an Restfläche</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">		der &#x22;Backenfassade&#x22; anpassen</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">		ca. 3 m²</span>
                        </p>
                        <p/>
                        <p>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Längen		Anschluss Wand waagrecht + senkrecht ca. 5,6 m</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">		Anschluss an Gaupendach ca. 5 m</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">		Anschluss an Hauptdach ca. 3,5 m</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">		Anschluss an Attika ca. 2,5 m</span>
                          <br/>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Gehrungs- und Schrägschnitte, Anarbeiten, abschnittsweise Herstellung, Kleinflächen und Nischen ohne doppeltes Aufmaß sind einzurechnen und werden nicht gesondert vergütet.</span>
                          <br/>
                          <br/>
                        </p>
                      </Text>
                    </DetailTxt>
                    <OutlineText>
                      <OutlTxt>
                        <TextOutlTxt>
