<GAEB xmlns="http://www.gaeb.de/GAEB_DA_XML/DA83/3.2"><GAEBInfo><Version>3.2</Version><VersDate>2013-10</VersDate><Date>2026-04-17</Date><Time>08:44:46</Time><ProgSystem>SJ AVA/ GXML Toolbox V3.2 R20131205</ProgSystem><ProgName>SJ AVA</ProgName></GAEBInfo><PrjInfo><NamePrj>TAA-25-9</NamePrj><LblPrj>Flechtingen Grundschule -  Außenanlagen</LblPrj><Cur>EUR</Cur><CurLbl>Euro</CurLbl></PrjInfo><Award><DP>83</DP><AwardInfo><Cur>EUR</Cur><CurLbl>Euro</CurLbl></AwardInfo><OWN><Address><Name1>Verbandsgemeinde Flechtingen</Name1><Street>Lindenplatz 11-15</Street><PCode>39345</PCode><City>Flechtingen</City></Address><DPNo>TAA-25-9</DPNo></OWN><AddText><OutlineAddText><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Vorbemerkungen</span></p></OutlineAddText><DetailAddText><p style="margin-right:221pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">B A U K U R Z B E S C H R E I B U N G</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">1.0 Angaben zur Baustelle</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Das Schulgelände der Grundschule Flechtingen liegt südöstlich des Ortskerns der Gemeinde Flechtingen. Verkehrlich wird die Schule durch die L 43, die Straße</span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">„Vor dem Tore&#x22; erschlossen. Das Gelände ist eben. </span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Die vorhandene Laufbahn, die Weitsprunggrube und </span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">der Maschendrahtzaun im südlichen Bereich des </span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Grundstücks 939 sollen rückgebaut werden. Das </span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Flurstück 943 ist eine Brachfläche, welche in der Ver-</span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">gangenheit durch die TWM mit einem Pumpenhaus </span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">und einem Wasserbecken für Filterrückspülungen </span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">und durch die Avacon mit einem Trafogebäude </span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">genutzt wurden. Alle Anlagen sind abgerissen </span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">und das Grundstück der Gemeinde ist zur Zeit </span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">ungenutzt. Es ist mit dem Auffinden von Funda-</span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">mentresten und Schotterflächen zu rechnen. Diese </span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Fläche soll in Zukunft der Grundschule zur Nutzung </span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">überlassen werden.</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Als Zwischenlager für Baustoffe muss das Baufeld </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">genutzt werden. Baustrom und Bauwasser im Baufeld </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">sind in Abstimmung mit dem zuständigen Versorgungs-</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">träger nutzbar. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">2.0 Aufgabenstellung</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:221pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Die Gemeinde Flechtingen plant die Umgestaltung </span></p><p style="margin-right:221pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">und Erweiterung der Aussenanlagen ihrer Grundschule entsprechend dem Ausbauprogramm Schulhoftrans-</span></p><p style="margin-right:221pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">formation Pandemieresilenter Ausbau (SchulPandA). </span></p><p style="margin-right:221pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Das Gebäudeensemble der Grundschule ist in den vergangenen 10 Jahren kontinuierlich erneuert und </span></p><p style="margin-right:221pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">saniert worden. Die Außenanlagen sollen nun er-</span></p><p style="margin-right:221pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">weitert und in einigen Teilen erneuert, bzw. umge-</span></p><p style="margin-right:221pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">staltet werden. Es soll gesamtheitlich eine Ver-</span></p><p style="margin-right:221pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">besserung des Angebotes der Sport-, Spiel- und </span></p><p style="margin-right:221pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Lernangebote erfolgen.</span></p><p style="margin-right:223pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Es handelt sich um eine Ausschreibung (Los 001) </span></p><p style="margin-right:223pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">der Verbandsgemeinde Flechtingen.</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">3.0 Baubeschreibung</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Maßnahmen:</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Entlang der südlichen Seite der Bushaltestelle </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">wird eine 2,66 m breite Gehbahn mit errichtet.</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:221pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Gehbahn Bushaltestelle</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial Narrow;font-size:12pt;">  8 cm</span><span style="font-family:Arial;font-size:10;mso-tab-count:1;">   </span><span style="font-family:Arial Narrow;font-size:12pt;">Betonsteinpflaster nach DIN EN 1338</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;">Erzeugnis Rechteckstein, Farbe grau</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;">Verlegung in Läuferverband, Format </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;">21x10,5x8 cm, Fugen mit Brechsand </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;">0/5 mm einschlämmen</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial Narrow;font-size:12pt;">  4 cm</span><span style="font-family:Arial;font-size:10;mso-tab-count:1;">   </span><span style="font-family:Arial Narrow;font-size:12pt;">Brechsand - Splittgemisch 0/5</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm 25.20mm 37.80mm 50.40mm;"><span style="font-family:Arial Narrow;text-decoration:underline;font-size:12pt;">25 cm</span><span style="font-family:Arial;font-size:10;mso-tab-count:1;">   </span><span style="font-family:Arial Narrow;text-decoration:underline;font-size:12pt;">Frostschutzschicht 0/45</span><span style="font-family:Arial;font-size:10;mso-tab-count:1;"/><span style="font-family:Arial Narrow;text-decoration:underline;font-size:12pt;"/><span style="font-family:Arial;font-size:10;mso-tab-count:1;"/><span style="font-family:Arial Narrow;text-decoration:underline;font-size:12pt;"/><span style="font-family:Arial;font-size:10;mso-tab-count:1;">  </span><span style="font-family:Arial Narrow;text-decoration:underline;font-size:12pt;"/></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm 25.20mm 37.80mm 50.40mm;"><span style="font-family:Arial Narrow;font-size:12pt;">37 cm</span><span style="font-family:Arial;font-size:10;mso-tab-count:1;">   </span><span style="font-family:Arial Narrow;font-size:12pt;">frostsicherer Oberbau</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Für die Randeinfassung sind Tiefbordsteine 8/25 </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">mit Rückenstütze und Betonbettung C 16/20 vor-</span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">gesehen. Die Fläche hat ein Quergefälle von </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">2,5 % in Richtung des Entwässerungsgrabens,</span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">welcher sich zwischen der Bushaltestelle und </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">dem neuen Weg befindet.  </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Wegesystem Freifläche</span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Die Wege in den Freiflächen werden durch 1,50 m </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">breite geschwungene Wege mit einer gelben sand-geschlämmten Splitt- Schotterandeckung - 2 cm </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Brechsand Farbe gelb 0/4 mm, 3 cm Splitt 2/5 </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Farbe gelb und 25 cm Frostschutzschicht 0/45 - </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">verbunden. Die Randeinfassung wird durch ein-</span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm 25.20mm;"><span style="font-family:Arial Narrow;font-size:12pt;">reihige Betonsteine 16/16/14 Farbe grau in </span><span style="font-family:Arial;font-size:10;mso-tab-count:1;"/><span style="font-family:Arial Narrow;font-size:12pt;"/><span style="font-family:Arial;font-size:10;mso-tab-count:1;"/><span style="font-family:Arial Narrow;font-size:12pt;">Betonbettung und Rückenstütze Beton C 16/20 </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">realisiert.</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Hochbeete, Südlicher Zugang Schulgebäude</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Auf der Süd- und Westseite der Schulgebäude </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">sollen für eine zusätzliche künftige Verschattung </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">vier Hochbeete angelegt werden. Sie enthalten </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">je einen Großbaum und eine Unterpflanzung aus </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Stauden und mineralischen Mulch. Die Einfassung </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">erfolgt mit Blockelementen aus Beton, Oberfläche </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">kugelgestrahlt, in den Abmessungen 0,40 / 0,55 / </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">1,50-2,0 m (B / H / L).  </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Auf den Elementen wird eine Beplankung zum </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Sitzen aufgebracht. Die Gründung der Elemente </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">erfolgt auf 35 cm Schotter Körnung 0/45 und einem </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Fundament aus Beton C 20/25. </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Der südliche Zugang der Schule ist neu herzustellen. </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Das in Teilflächen vorhandene unebene Pflaster wird aufgenommen. Der Traufstreifen ist in diesem Abschnitt</span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">aus Betonplatten 40 x 40 x 5 cm herzustellen. Der Eingangsbereich zu den Gebäuden, in welchem sich </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">eine Fluchttreppe aus Metall befindet wird mit Beton-</span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">steinpflaster befestigt.</span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial Narrow;font-size:12pt;">  8 cm</span><span style="font-family:Arial;font-size:10;mso-tab-count:1;">   </span><span style="font-family:Arial Narrow;font-size:12pt;">Betonsteinpflaster nach DIN EN 1338</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;">Erzeugnis Rechteckstein, Farbe grau</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;">Verlegung in Ellbogenverband, Format </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;">21x10,5x8 cm, Fugen mit Brechsand </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;">0/5 mm einschlämmen</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial Narrow;font-size:12pt;">  4 cm</span><span style="font-family:Arial;font-size:10;mso-tab-count:1;">   </span><span style="font-family:Arial Narrow;font-size:12pt;">Brechsand - Splittgemisch 0/5</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm 25.20mm 37.80mm 50.40mm;"><span style="font-family:Arial Narrow;text-decoration:underline;font-size:12pt;">25 cm</span><span style="font-family:Arial;font-size:10;mso-tab-count:1;">   </span><span style="font-family:Arial Narrow;text-decoration:underline;font-size:12pt;">Frostschutzschicht 0/45</span><span style="font-family:Arial;font-size:10;mso-tab-count:1;"/><span style="font-family:Arial Narrow;text-decoration:underline;font-size:12pt;"/><span style="font-family:Arial;font-size:10;mso-tab-count:1;"/><span style="font-family:Arial Narrow;text-decoration:underline;font-size:12pt;"/><span style="font-family:Arial;font-size:10;mso-tab-count:1;">  </span><span style="font-family:Arial Narrow;text-decoration:underline;font-size:12pt;"/></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm 25.20mm 37.80mm 50.40mm;"><span style="font-family:Arial Narrow;font-size:12pt;">37 cm</span><span style="font-family:Arial;font-size:10;mso-tab-count:1;">   </span><span style="font-family:Arial Narrow;font-size:12pt;">frostsicherer Oberbau</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">In diese Fläche ist eine Sauberlaufstrecke aus </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">mehreren Fussabstreiferkästen einzubauen. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:232pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Zugang Schulgebäude, Aktionsflächen </span></p><p style="margin-right:232pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:232pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Ein weiteres bestehendes Areal mit Schotter-/ Splittandeckung aus Richtung Lillienweg wird </span></p><p style="margin-right:232pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">zur aktiven Nutzung ausgebaut. Die Fläche </span></p><p style="margin-right:232pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">kann dann als Fahrradparcours für Verkehrs-</span></p><p style="margin-right:232pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">schulungen oder für Skateboards und Inline-</span></p><p style="margin-right:232pt;text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial Narrow;font-size:12pt;">skatern </span><span style="font-family:Arial;font-size:10;mso-tab-count:1;"> </span><span style="font-family:Arial Narrow;font-size:12pt;">genutzt werden. Diese Fläche wird mit  Betonsteinpflaster befestigt. </span></p><p style="margin-right:232pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial Narrow;font-size:12pt;">  8 cm</span><span style="font-family:Arial;font-size:10;mso-tab-count:1;">   </span><span style="font-family:Arial Narrow;font-size:12pt;">Betonsteinpflaster nach DIN EN 1338</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;">Erzeugnis Rechteckstein, Farbe grau</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;">Verlegung in Ellbogenverband, Format </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;">21x10,5x8 cm, Fugen mit Brechsand </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;">0/5 mm einschlämmen</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial Narrow;font-size:12pt;">  4 cm</span><span style="font-family:Arial;font-size:10;mso-tab-count:1;">   </span><span style="font-family:Arial Narrow;font-size:12pt;">Brechsand - Splitt- Gemisch 0/5</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">15 cm   Schottertragschicht 0/32</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm 25.20mm 37.80mm 50.40mm;"><span style="font-family:Arial Narrow;text-decoration:underline;font-size:12pt;">30 cm</span><span style="font-family:Arial;font-size:10;mso-tab-count:1;">   </span><span style="font-family:Arial Narrow;text-decoration:underline;font-size:12pt;">Frostschutzschicht 0/45</span><span style="font-family:Arial;font-size:10;mso-tab-count:1;"/><span style="font-family:Arial Narrow;text-decoration:underline;font-size:12pt;"/><span style="font-family:Arial;font-size:10;mso-tab-count:1;"/><span style="font-family:Arial Narrow;text-decoration:underline;font-size:12pt;"/><span style="font-family:Arial;font-size:10;mso-tab-count:1;">  </span><span style="font-family:Arial Narrow;text-decoration:underline;font-size:12pt;"/></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm 25.20mm 37.80mm 50.40mm;"><span style="font-family:Arial Narrow;font-size:12pt;">57 cm</span><span style="font-family:Arial;font-size:10;mso-tab-count:1;">   </span><span style="font-family:Arial Narrow;font-size:12pt;">frostsicherer Oberbau</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:233pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Zur Anleitung des  Niederschlagswasser ist eine </span></p><p style="margin-right:233pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">2-zeilige Rinne aus Betonsteinen16/16/14 cm </span></p><p style="margin-right:233pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">geplant. Die Entwässerung wird an das Regen-</span></p><p style="margin-right:233pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">wasssernetz im Lillienweg angeschlossen. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Laufbahn, Weitsprunggrube </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Auf der Südseite des Grundstückes soll eine </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">neue Lauf- und Weitsprunganlage angelegt </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">werden. Die 50,0 m Laufbahn mit 3,0 m Start-</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">raum und einem Auslauf von 12,0 m hat eine </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Gesamtlänge von 65,0 m und besteht aus </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Kunststoff. Am Auslaufende der Bahn schließt </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">eine Weitsprunganlage an. </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Befestigungsaufbau Laufbahn: </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;"> 2,0 cm Kunststoffbelag DIN EN 14877,</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;">Normtyp ziegelrot</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;"> 2,5 cm obere bituminöse gebundene wd Trag-</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;">schicht DIN 18035 Körnung 5 mm Binde-</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;">mittel 70/100</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;"> 4,0 cm untere bituminöse gebundene Trag-</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;">schicht DIN 18035 Körnung 11 mm </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;">Bindemittel 70/100</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;"> 8,0 cm obere ungebundene Tragschicht DIN </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;">18035, Körnung 0/16 mm</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">33,0 cm untere ungebundene Tragschicht DIN</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;">18035, Körnung 0/32 mm</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">10,0 cm Filterschicht Mineralgemisch B 2 DIN</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;">18123, Körnung 0/32  </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Die Laufbahnanlage teilt sich in drei Laufbahnen </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">mit je 1,22 m Breite auf. Die Randeinfassung der </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Laufbahn besteht aus einem Tiefbordsteinen. </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Entlang der Einfassungen der Laufbahn ist  eine Randaussparung 2/2 cm (Tiefe/Breite) auf der </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Laufbahnseite einzuarbeiten. Der Sicherheitsbe-</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">reich der Laufbahn wird mit Betonsteinpflaster</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">befestigt. </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Die Weitsprunganlage hat Abmessungen von ca.</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">9,0 m Länge x 3,00 m Breite. Sie wird eingefasst </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">mit Randsteinen aus Polymerbeton an die sich</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">umlaufend U-förmig eine Sandfangrinne aus </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Kunststoff und eine arretierte Gummimatte </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">anschließt. Die 0,40 m starke Befüllung der </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Sprunggrube erfolgt mit Sand der Körnung </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">0,2 - 2 mm, ohne bindige Anteile. Unter der </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Sandschicht wird ein Unkrautvlies und eine 15 cm Frostschutzschicht  0/45 eingebaut. Den Abschluß </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">gegenüber dem anstehenden Boden bildet ein Vlies.</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Am Startraum wird eine vergrößerte Aufstellfläche </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">mit Betonsteinpflaster und zwei Bänken angelegt.</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Schulgarten</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Auf einer Fläche von 10 x 12 m ist ein Schulgarten vorgesehen. Der Garten ist mit einem Tiefbord</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial Narrow;font-size:12pt;">abgegrenzt. Diese Fläche erhält eine 20 cm </span><span style="font-family:Arial;font-size:10;mso-tab-count:1;"/><span style="font-family:Arial Narrow;font-size:12pt;">Oberbodenschicht mit Rasenansasat. Westlich der Gartenfläche wird ein Gerätehaus aufgestellt. </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Ein Brauchwasseranschluß aus PE-Rohr DN 25</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">ist geplant. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Bühnenfläche und &#x22;Grünes Klassenzimmer&#x22;</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:231pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Zentral auf dem Gelände der Freiflächen ist eine </span></p><p style="margin-right:231pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">kleine Bühne geplant und ihr gegenüber zweistufige Sitzreihen. Diese Anlage ist kreisförmig angelegt.</span></p><p style="margin-right:231pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Die Bühnenfläche befindet sich 30 cm über GOK. </span></p><p style="margin-right:231pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">In den Flächen der Bühne werden Betonplastersteine</span></p><p style="margin-right:231pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">und Betonpalisaden verbaut.  eingefasst und mit Betonpflastersteinen befestigt.</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Der Übergang zum umliegenden Gelände erfolgt </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">mit einer Böschung aus Oberboden.</span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Das „grüne Klassenzimmer&#x22; umfasst eine Beton-</span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">pflasterfläche eingefasst mit Tiefbordsteine.</span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Kletterparcours</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Auf der Spielplatzfläche wird ein Kletterparcours </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">errichtet. Auf einer Grundfläche von 12 x 12 m </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">werden mehrere Kletter- Hangel und Schwing-</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">elemente aufgestellt. </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Als Unterlage sollen 10 cm starke Fallschutzmatten </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">mit folgendem Schichtenaufbau verlegt werden:</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;"> 7 cm Fallschutzmatten 500 x 500 mm </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">          aus recycelbarem Gummigranulat, </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">          Montage mit Steckverbindern, Farbe </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">          rotbraun </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;"> 2 cm Unterlegmatte</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;"> 4 cm Splitt-Brechsandgemisch 0/8 mm</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">10 cm Drainbeton</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">30 cm  Frostschutzschicht 0/45</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Für die Randeinfassung kommen Tiefbordsteine </span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">aus Beton 8/25 zur Anwendung.</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Sandspielfläche</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Um die vorhandene Spielekombination ist die </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">vorhandene Sandfläche zu erneuern und zu </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">vergrößern. Als Abgrenzung zur Grünfläche </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">ist die Fläche mit Robinienstämmen einzufassen.</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Entwässerung</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Es sind der Straßenablauf von der Aktionsfläche </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">und der Bühne mittels einer Rohrleitung PP-Rohr </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">DN 150 und von der Sandfangrinne und dem Weitsprungbalken mit einer Leitung PP-Rohr </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">DN 100 an das Niederschlagswassernetz im </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Lilienweg anzuschließen. Parallel zur Laufbahn </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">ist eine Dränleitung DN 100 zu verlegen, welche </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">an die Leitung DN 150 zum Lilienweg anzubinden </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">ist.</span></p><p style="margin-left:35pt;text-align:justify;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Ausstattung Schulhof</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Auf dem bereits bestehenden Gelände sollen </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">noch eine vorhandene vor dem Schuleingang </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">demontierte Tischtennisplatte, zwei Baketball-</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">körbe mit Kettenkorb und wetterfestem Zielbrett </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">und vor einer neu zu errichtenden Zaunanlage </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">4 wetterfeste Maltafeln angeordnet werden.</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Weiterhin werden noch zwei Flächen mit </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Gummi-Spielmatten belegt.</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Spielgeräte</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:222pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Mehrere Spielgeräte sind umzusetzen und es</span></p><p style="margin-right:222pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">kommt zur Ergänzung einiger neuer Einbauten. </span></p><p style="margin-right:222pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Einfriedung</span></p><p style="margin-right:232pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:232pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">In Teilabschnitten des Schulhofes und der</span></p><p style="margin-right:232pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Freiflächen kommt es zum Einbau einer neuen</span></p><p style="margin-right:232pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Zaunanlage als Doppelstabmattenzaun von</span></p><p style="margin-right:232pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">1,40 bzw. 1,80 m Höhe mit Tor-Türeinbauten.</span></p><p style="margin-right:232pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Beleuchtung</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:231pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Das Außengelände soll noch durch fünf Mast-</span></p><p style="margin-right:231pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">aufsatzleuchten ausgeleuchtet werden. Dabei </span></p><p style="margin-right:231pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">soll auch die Nutzung in der dunklen Jahreszeit </span></p><p style="margin-right:231pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">ermöglicht werden. Gleichzeitig wird ein ab-</span></p><p style="margin-right:231pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">schreckender Effekt gegen nächtlichen Vanda-</span></p><p style="margin-right:231pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">lismus erreicht werden.</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Begrünung</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Generell besteht die Begrünung hauptsächlich </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">aus Rasenansaat. Strukturiert wird das neu </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">gestaltete Ensemble durch Baumpflanzungen </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">unterschiedlicher Sorten und auch Pflanz-</span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">qualitäten und durch einige Großsträucher. </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Zentral soll noch ein kleiner begehbarer </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Bambushain angelegt werden, welcher zu </span></p><p style="margin-right:228pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Fang- und Versteckspielen einlädt.</span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Als südlicher Randabschluß des Geländes soll</span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">ein Gehölzstreifen zum Sicht- und Lärmschutz </span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">zum angrenzenden Eigenheimgebiet am Lilien-</span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">weg etabliert werden. Hier werden Stauden, </span></p><p style="margin-right:227pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Sträucher und einige Bäume gepflanzt.</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Folgende Punkte sind zu beachten:</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Die Baustellensicherung erfolgt auf dem Schul-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">gelände in den Bereichen der Baufelder. Eine </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Verkehrssicherung erfolgt an der L 43 im Bereich </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">der Zufahrt zur Baustelle und beim Wegebau an </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">der Bushaltestelle.</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Die Nachweise für die Verdichtung der Rohr-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">gräben sowie des Straßenbaus sind mit dem </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Ausbau zu erbringen (dyn. Plattendruckversuche).</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Die Zuwegungen zu den Hauseingängen an der </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Schule sind durch den AN sicherzustellen.</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">4.0 Verkehrsführung</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Verkehrstechnisch ist das Baugelände für das </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Vorhaben über die L 43 aus beiden Richtungen </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">erreichbar. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">5.0 Baugrundverhältnisse</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Für die vorliegende Baumaßnahme wurde kein ge-</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">sondertes Baugrundgutachten erarbeitet. Zur Beur-</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">teilung der Baugrundverhältnisse wurde der unserem </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Büro vorliegende Geotechnische Bericht Nr. 07/04/09 </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial Narrow;font-size:12pt;">vom Ingenieurbüro Dipl.-Ing. U. </span><span style="font-family:Arial;font-size:10;mso-tab-count:1;"/><span style="font-family:Arial Narrow;font-size:12pt;">Nachtigall vom </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">08.04.2008 herangezogen. Das Untersuchungsgebiet </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">befindet sich ca. 100 m westlich der Grundschule </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Flechtingen. Die obere unterschiedlich mächtige Auffüllungsschicht ist anthropogen beeinflusst und </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">besteht aus Mischböden, Sand, Mutterboden und Brechkornresten. Ab einer Tiefe von 0,60 cm bis </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">0,80 cm steht feinsandiger, stark schluffiger Mittel-</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">sand an. Ein geschlossener Grundwasserleiter </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">wurde nicht angetroffen. Es ist jedoch mit dem </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Auftreten von Schichtenwasser zu rechnen.</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;text-decoration:underline;font-size:12pt;">Schlussfolgerungen</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Die zu erwartenden Böden im Bereich des Planums </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">sind in die Frostempfindlichkeitsklasse F 3 einzustufen  </span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Beim Nichterreichen der geforderten Tragfähigkeits-</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">werte des Planums von EV2 = 45 MPa sind Nachverdichtungen, ggf. eine Verstärkung der Frostschutzschichten erforderlich. Hierzu sind Ab-</span></p><p style="margin-right:229pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">stimmungen mit dem bauleitenden Planungsbüro durchzuführen.</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">6.0 Behinderungen</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:222pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Im Baubereich sind Leitungsmedien der Elektro-, </span></p><p style="margin-right:222pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Telekommunikation-, Trinkwasser- und Gasver-</span></p><p style="margin-right:222pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">sorgung vorhanden. Schmutz- und Regenwasser-</span></p><p style="margin-right:222pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">kanäle sind ebenfalls vorhanden. Diese Leitungen </span></p><p style="margin-right:222pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">sind vor Baubeginn durch den AN zu orten. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:222pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Dem Verkehr im Baubereich sowie dem Anlieger-</span></p><p style="margin-right:222pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">verkehr während einer Bauzeit ist Rechnung zu </span></p><p style="margin-right:222pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">tragen. Die fußläufigen Zuwegungen zu den Hausein-</span></p><p style="margin-right:222pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">gängen während der Bauzeit sind vom Baubetrieb sicherzustellen. Gleichzeitig ist den Forderungen </span></p><p style="margin-right:222pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">der Feuerwehr und dem Krankentransport nachzu-</span></p><p style="margin-right:222pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">kommen. Die Arbeiten sind so zu organisieren, </span></p><p style="margin-right:222pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">daß Havarieeinsätze problemlos möglich sind.</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:224pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Teilweise treten beengte Platzverhältnisse bei der </span></p><p style="margin-right:224pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Befahrung auf dem Baugelände auf, welche zu </span></p><p style="margin-right:224pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">beachten sind. Hier kann es zu Einschränkungen </span></p><p style="margin-right:224pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">bei Arbeiten mit großen Baugeräten und -fahrzeugen </span></p><p style="margin-right:224pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">kommen. </span></p><p style="margin-right:224pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:224pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">Da die Bauarbeiten auch zeitlich mit dem Schul-</span></p><p style="margin-right:224pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">betrieb zusammenfallen, ist eine ständige Ab-</span></p><p style="margin-right:224pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">sicherung des bespielten Schulgeländes zu</span></p><p style="margin-right:224pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;">gewährleisten. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:10.00mm;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">7.0</span><span style="font-family:Arial;font-size:10;mso-tab-count:1;">     </span><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);"> Weitergehende Hinweise zur Bauausführung</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Der Ausschreibung liegen die VOB A/B u. C mit allen Er-</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">gänzungen in der letzten Fassung, die zur Zeit gültigen </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">ZTVs für die Ausführung von Bauleistungen sowie die </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">ATV- DVWK- Arbeitsblätter und die DIN EN 1610 zugrunde.  </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Der Unternehmer hat sich vor Angebotsabgabe rechzeitig </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">und umfassend über die örtlichen Verhältnisse zu unter- richten. Nachträgliche Forderungen, infolge mangelhafter Erkundigungen werden nicht vergütet.</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Vor Beginn der Bauarbeiten ist mit dem baubetreuenden </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Planungsbüro ein Uraufmaß durchzuführen.</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Unverzüglich nach der Auftragserteilung ist ein verbindlicher </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Bauablaufplan vorzulegen. Dieser wird Vertragsbestandteil. </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Außerdem ist vor dem Baubeginn vom beauftragten Bau- unternehmen die Urkalkulation in einem verschlossenen </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Briefumschlag beim Auftraggeber zu hinterlegen.</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Vor dem Baubeginn ist dem Auftraggeber eine Aufstellung </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">der für die Baustelle verantwortlichen Arbeitskräfte zu über- geben. Diese muss auch die Qualifikation der Arbeitskräfte </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">enthalten. Der Bauleiter und Polier muss für die gesamte Bauzeit die Baustelle betreuen.</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Mit Behinderungen bei den Bauarbeiten durch vorhandene </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Leitungen und Kabel ist zu rechnen. Die Zustimmung der </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Rechtsträger zur Durchführung der Arbeiten ist vor Beginn durch den Baubetrieb einzuholen bzw. eine örtliche Ein-weisung ist vorzusehen. Die dafür entstehenden Kosten </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">sind in die Einheitspreise einzukalkulieren. Die bei Unterlassung hierdurch evtl. entstehenden Schäden gehen </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">zu Lasten des AN.</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Die Position &#x22;Suchschachtung&#x22; ist nur auf Anordnung des </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">AG auszuführen, ansonsten besteht kein Vergütungs-anspruch. Suchschachtungen sind in ihrer ausgeschrie-</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">benen Größe (L/B/H) in Bezug auf die vorgefundene Lage </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">der Ver- und Entsorgungsleitungen (mehrere Leitungen innerhalb einer Suchschachtung) anzahlmäßig aufzugliedern.  </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Eventuell erforderlicher Handaushub, insbesondere im </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Bereich von Leitungen, Kanälen, Schächten, Kabeltrassen, </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Kabelanlagen, Bauwerken, Einfriedungsmauern, sonstiger </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Abgrenzungen, Lichtschächten, Schiebern oder ähnlichen </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Bauprodukten, ist als Erschwernis in die Einheitspreise </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">einzukalkulieren. </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Es ist bei den Erdarbeiten die DIN 18920 - Arbeiten im </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Wurzelbereich von Bäumen ... - zu beachten und umzu- setzen. Im Wurzelbereich ist Handschachtung angeordnet.</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Für die Überwachung der Ausführungen von Bauleistungen </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">muß eine geeignete Fachkraft ständig auf der Baustelle </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">anwesend sein. Bautagesberichte sind täglich zu führen </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">und wöchentlich dem Bauherrn zu übergeben.  </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Die verkehrsrechtliche Anordnung zum Sperren von </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Straßen ist vom AN bei dem zuständigen Straßenver-</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">kehrsamt einzuholen. Eine allgemeine Absperrung der Baustelle ist im Leistungsverzeichnis mit ausgeschrieben, </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">d.h. Sicherung von Bauanfang und -ende. Absperrungen </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">und Sicherungen von Baugruben usw. innerhalb des Bau-feldes im Zuge der Bauarbeiten werden nicht gesondert vergütet. Diese gehören zur fachgerechten Ausführung </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">der Bauleistung unter Einhaltung der Unfallverhütungs-vorschriften. </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Sollten die Unfallverhütungsvorschriften der Tiefbau-</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Berufsgenossenschaft nicht eingehalten werden, wird </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">die Baustelle durch die Bauleitung des AG stillgelegt. </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Dadurch entstehende Kosten bzw. Mehrkosten der Bauleistungen gehen zu Lasten des AN.</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">In Anspruch genommener Verkehrsraum sowie sonstige Flächen für Lagerungszwecke und die Baustelleneinrichtung sind wie vorgefunden wieder herzurichten. Entstehende Kosten hierfür sind in die Einheitspreise einzukalkulieren. </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Das Ablegen von Baumaterial in freizuhaltenden Verkehrs-raum ist nicht gestattet.</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Dem AN obliegt für alle zur Wiederverwendung nicht </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">geeigneter Stoffe oder Materialien die ordnungsgemäße </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Entsorgung und Deponierung. Hierzu hat der AN Ort und </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Name der zur Deponierung vorgesehenen und abfallrecht-</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">lich geeigneten Stelle zu benennen und zum Nachweis der </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Entsorgung entsprechende Entsorgungsnachweise seinen </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Rechnungen beizulegen.</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Vor der Materialbestellung sind vom AN genaue Nachrech-</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">nungen der Mengenansätze des Leistungsverzeichnisses </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">aufzustellen. Evtl. Veränderungen sollten bei der Material-</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">bestellung Berücksichtigung finden. Kosten aufgrund </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">übrigbleibender Materialien durch fehlerhafte Bestellung </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">werden vom AG nicht anerkannt. </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Das Leistungsverzeichnis gilt bezüglich der Mengen nicht </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">als Bestellunterlage.</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Nachträge sind grundsätzlich mit einer prüffähigen Kalkulation mit Bezug auf die Kalkulation aus dem Hauptangebot einzureichen. </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Abnahmen und Aufmaße sind rechtzeitig anzumelden. </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Feststellungen für technische Abnahmen, zu den Aufmaßen </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">und zur Abrechnung sind nur gemeinsam mit dem Bauleiter </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">des Ingenieurbüros zu treffen. Anderenfalls besteht die </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Beweislast allein beim AN.  </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Zu allen Rechnungen (auch Abschlagsrechnungen) sind be-</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">stätigte Aufmaße einzureichen.</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Die Mengenermittlung für die Schlußrechnung der Leistung </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">erfolgt nach Bestandsskizzen, die mit der Schlußrechnung </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">vorzulegen sind.</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Von den zum Einbau kommenden Schüttgütern und </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Materialien sind vor den Bauarbeiten die Qualitätszer-</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">tifikate vorzulegen. Diese dürfen nicht älter als 6 Monate </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">sein. Ohne die Vorlage dieser Zertifikate darf kein Material eingebaut werden.</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Zum Schlußaufmaß gehört ein Materialnachweis sämtlicher </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">eingebauter Stoffe, einschließlich der Schüttgüter. </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Diese sind per Lieferschein geordnet und in chronologischer </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Reihenfolge im Orginal, mit Bestätigungsvermerk der Bau-leitung, vorzulegen. </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Folgende Verrechnungsgewichte sind dabei verbindlich: </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:10.00mm 40.70mm 60.80mm;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Sand/Kies/Splitt    1,9 t/cbm  verdichtet</span><span style="font-family:Arial;font-size:10;mso-tab-count:1;"/><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);"/></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Mineralgemisch    2,2 t/cbm  verdichtet</span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Bitumengemisch   2,5 t/cbm  verdichtet   </span><span style="font-family:Arial;font-size:10;mso-tab-count:1;"/><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">       </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;tab-stops:12.60mm;"><span style="font-family:Arial;font-size:10;mso-tab-count:1;">            </span><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);"/></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Die Beseitigung auftretenden Niederschlagswassers inner- halb der Baugruben ist in die Einheitspreise einzukalkulieren und wird nicht gesondert vergütet. </span></p><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="margin-right:230pt;text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx</span></p></DetailAddText></AddText><BoQ ID="id1"><BoQInfo><Name>001</Name><LblBoQ>Grundschule Flechtingen - Außenanlagen</LblBoQ><Date>2024-01-18</Date><OutlCompl>AllTxt</OutlCompl><BoQBkdn><Type>BoQLevel</Type><LblBoQBkdn>Los</LblBoQBkdn><Length>2</Length><Num>Yes</Num></BoQBkdn><BoQBkdn><Type>BoQLevel</Type><LblBoQBkdn>Hauptabschnitt</LblBoQBkdn><Length>2</Length><Num>Yes</Num></BoQBkdn><BoQBkdn><Type>Item</Type><LblBoQBkdn>Position</LblBoQBkdn><Length>4</Length><Num>Yes</Num></BoQBkdn><NoUPComps>0</NoUPComps><LblTime>Stunden</LblTime></BoQInfo><BoQBody><BoQCtgy RNoPart="1" ID="id2"><LblTx><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Baustelleneinrichtung</span></p></LblTx><BoQBody><BoQCtgy RNoPart="1" ID="id3"><LblTx><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Baustelleneinrichtung</span></p></LblTx><BoQBody><Itemlist><Item RNoPart="1" ID="id4"><Qty>1.000</Qty><QU>St</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">An- und Abtransport, betriebsfertiges Einrichten, </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Vorhaltung, Betrieb sowie Räumung aller für die vertragsgemäße Ausführung der gesamten Bau-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">leistungen zum Tief-, Landschafts- und Metallbau erforderlichen Gerätschaften, Werkzeuge, Ma-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">schinen, Fahrzeuge, Absperrvorrichtungen, Bau-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">schilder, Baubeleuchtung, Bauwagen bzw. -con-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">tainer, Toiletten, Energie- und Bauwasseran-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">schlüsse usw. für das Los 001. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Einrichtung, Unterhaltung und Beräumung von </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Lagerplätzen, Material- und Gerätelager. Unter-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">haltung der Zufahrtswege, einschl. der Beseiti-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">gung aller von den Bauarbeiten herrührenden </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Schäden und Verunreinigungen auf dem für </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">die Baustelle benutzten Gelände und den an-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">liegenden öffentlichen Straßen. Stellen von not-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">wendigen Behältern zur Rückhaltung des an-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">fallenden Schmutzes auf der Baustelle.</span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Baustelleneinrichtung/-vorhaltung/-räumung</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="2" ID="id5"><Qty>1.000</Qty><QU>St</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Verkehrssicherung und Baustellensicherung für </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">die vertragsgemäße Ausführung der gesamten </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Bauleistungen zum Straßen-, Wege- und Frei-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">flächenbau sowie der Verlegung von Ver- und Entsorgungsleitungen auf dem Baugelände und </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">den Zufahrten zum Baugelände der Schule für den </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Fahr- und Fußgängerverkehr während der gesamten </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Bauzeit vornehmen. Die fußläufigen Zuwegungen </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">zu den Eingängen sowie die Zufahrt für Rettungs-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">fahrzeuge und die Feuerwehr muss gesichert sein. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Absperrgeräte, Warnzeichen, Beleuchtungmittel und Beleuchtungskörper für die Dauer der Baumaßnahme entsprechend der Verkehrsvorschriften betreiben und unterhalten. Abstimmungen mit der Gemeinde Flechtingen </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">und der Straßenverkehrsbehörde sowie dem Bauherrn </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">sind eigenverantwortlich durchzuführen. Die Zustimmung </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">des Straßenverkehrsamtes und die verkehrsrechtliche Anordnung sind einzuholen. Die Kosten dafür trägt der Auftragnehmer. Die Verkehrsschilder müssen unbedingt reflektierend sein. </span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Verkehrssicherung</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="3" ID="id6"><Qty>100.000</Qty><QU>m</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Absperrzaun nach Angaben des AG standsicher </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">herstellen, während der Bauzeit vorhalten und</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">unterhalten sowie nach Beendigung der Bauzeit </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">entfernen. Der Bauzaun ist zur Absperrung der </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Baustelle am Anfang und Ende sowie für die </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Absicherung entsprechend den Unfallver-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">hütungsvorschriften für Baugruben und Gräben </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">innerhalb des Baufeldes aufzustellen. Es gilt die </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">ZTV-SA &#x22; Zusätzliche technische Vertragsbe-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">dingungen und Richtlinien für Sicherungsarbeiten </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">an Arbeitsstellen an Straßen&#x22; als vereinbart. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">70 v.H. des Preises werden nach Aufstellung, </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">der Rest nach Entfernen des Bauzaunes vergütet. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Absperrschranke aus Kunststoff (HDPE), mit reflektie-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">render Folie, Standardausführung, Farben rot/weiß, </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Höhe ca. 1,00 bis 1,2 m. Ausführung Absperrschranken </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">mit Fußplatten.</span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Absperrzaun herst., vorh., entf. </span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="4" ID="id7"><Qty>20.000</Qty><QU>m</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Absperrzaun nach Angaben des AG standsicher </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">herstellen, während der Bauzeit vorhalten und</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">unterhalten sowie nach Beendigung der Bauzeit </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">entfernen. Der Bauzaun ist zur Absperrung der </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Baustelle am Anfang und Ende sowie für die </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Absicherung entsprechend den Unfallver-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">hütungsvorschriften für Baugruben und Gräben </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">innerhalb des Baufeldes aufzustellen. Es gilt die </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">ZTV-SA &#x22; Zusätzliche technische Vertragsbe-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">dingungen und Richtlinien für Sicherungsarbeiten </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">an Arbeitsstellen an Straßen&#x22; als vereinbart. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">70 v.H. des Preises werden nach Aufstellung, </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">der Rest nach Entfernen des Bauzaunes vergütet. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Absperrschranke aus Kunststoff (HDPE), mit reflektie-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">render Folie, Standardausführung, Farben rot/weiß, </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Höhe ca. 1,00 bis 1,2 m. Ausführung mit Stutzen </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">zur Befestigung von Warnleuchten und den er-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">forderlichen Richtstrahlern einseitig, gelbes </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Dauerlicht. Energieversorgung nach Wahl des AN. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Ausführung Absperrschranken mit Fußplatten.</span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Absperrzaun m. Leuchten herst., vorh., entf. </span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="5" ID="id8"><Qty>70.000</Qty><QU>m</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Absperrzaun abbauen, innerhalb der Baustelle </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">transportieren und nach Angabe des AG aufbauen.</span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Absperrzaun umbauen</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="6" ID="id9"><Qty>120.000</Qty><QU>m</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Bauzaun nach Angaben des AG standsicher herstellen, während der Bauzeit vorhalten und unterhalten sowie </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">nach Beendigung der Bauzeit entfernen. Der Bauzaun </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">ist zur Absperrung der Baustelle am Anfang und Ende </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">sowie für die Absicherung entsprechend den Unfallver-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">hütungsvorschriften für Baugruben und Gräben innerhalb </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">des Baufeldes aufzustellen. Es gilt die ZTV-SA &#x22; Zu-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">sätzliche technische Vertragsbedingungen und Richt-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">linien für Sicherungsarbeiten an Arbeitsstellen an </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Straßen&#x22; als vereinbart. 70 v.H. des Preises werden </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">nach Aufstellung, der Rest nach Entfernen des Bau-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">zaunes vergütet. </span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Bauzaun herst., vorh., entf.</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="7" ID="id10"><Qty>120.000</Qty><QU>m</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Bauzaun abbauen, innerhalb der Baustelle transportieren </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">und nach Angabe des AG aufbauen. </span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Bauzaun umbauen</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item></Itemlist></BoQBody></BoQCtgy></BoQBody></BoQCtgy><BoQCtgy RNoPart="2" ID="id11"><LblTx><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Schulhof</span></p></LblTx><BoQBody><BoQCtgy RNoPart="1" ID="id12"><LblTx><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Abbrucharbeiten</span></p></LblTx><BoQBody><Itemlist><Item RNoPart="1" ID="id13"><Qty>45.000</Qty><QU>m2</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Ungebundene Befestigungen aufbrechen und </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">aufnehmen, in Fahrbahnnebenflächen, aus </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">gebrochenem Naturstein, Dicke über 5 bis 15 cm. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Anfallende Stoffe beseitigen.  </span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Befest. gebr. Naturstein aufn., entsorgen</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="2" ID="id14"><Qty>10.000</Qty><QU>m3</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Tragschicht aufbrechen und aufnehmen aus Schotter. Gesamtaufbruchtiefe über 20 bis 30 cm. Material in </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Eigentum des AN übernehmen, von der Baustelle </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">entfernen und einer Wiederverwertung zuführen.</span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Tragschicht Schotter Tiefe 20 - 30 cm entfernen</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="3" ID="id15"><Qty>5.000</Qty><QU>m2</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Betonpflaster aufnehmen, Höhe 80 mm, Ausführung</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">in Fahrbahnnebenflächen, verlegt in Sand/Brechsand, Fugenfüllung aus Sand/Brechsand. Anfallende Stoffe beseitigen. </span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Betonpflaster aufnehm., ents.</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="4" ID="id16"><Qty>5.000</Qty><QU>m2</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Betonpflaster aufnehmen, Höhe 80 mm, Recht-</span><br/><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">eckstein, Ausführung in Gehwegen verlegt in</span><br/><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Sand/Brechsand, Fugenfüllung aus Sand/</span><br/><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Brechsand, Gesamtaufbruchtiefe ca. 10 cm.</span><br/><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Steine säubern und aufladen, zur Lagerstelle</span><br/><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">im Baubereich fördern und lagern, Förderweg</span><br/><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">bis 100 m.</span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Betonpflaster aufnehm., lagern</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="5" ID="id17"><Qty>2.000</Qty><QU>m</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Bordstein aus Beton aufnehmen, Form T, in </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Beton versetzt mit Rückenstütze als Tiefbord. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Dicke des Unterbetons bis 20 cm. Anfallende </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Stoffe beseitigen.  </span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Bordst. Form T aufn. entsorgen</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item></Itemlist></BoQBody></BoQCtgy><BoQCtgy RNoPart="2" ID="id18"><LblTx><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Erdarbeiten Wege</span></p></LblTx><BoQBody><Itemlist><Item RNoPart="1" ID="id19"><Qty>10.000</Qty><QU>m3</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Boden aus Abtragsstrecken profilgerecht lösen </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">und fördern. Klassen 3 bis 5. Das Herstellen des </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Planums wird gesondert berechnet. Boden geht </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">in Eigentum des AN über und wird beseitigt. Ab-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">gerechnet wird nach Abtragsprofilen.  </span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Boden Wege lösen, beseitig.</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="2" ID="id20"><Qty>45.000</Qty><QU>m2</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Planum herstellen. Zulässige Abweichung von  </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">der Sollhöhe +- 2 cm.</span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Planum +- 2cm</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="3" ID="id21"><Qty>45.000</Qty><QU>m2</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Untergrund verdichten, fuer Fahrbahnen, Ver-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">formungsmodul EV2 mind. 45 MPa, Boden-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">klasse 3 bis 5.</span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Untergrund verd.</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="4" ID="id22"><Qty>2.000</Qty><QU>m3</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Boden aus Abtragsstrecken profilgerecht lösen </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">und zur späteren Wiederverwendung zwischen-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">lagern. Klassen 3 bis 5. Boden innerhalb der </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Baustelle fördern und seitlich lagern. Mittl. Länge </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">des Förderweges bis 100 m. Das Herstellen des </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Planums wird gesondert berechnet. Abgerechnet </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">wird nach Abtragsprofilen. </span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Boden lösen, seitlich lagern, Bord</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="5" ID="id23"><Qty>2.000</Qty><QU>m3</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Gelagerten Boden aufnehmen, fördern, in den Auftragsstrecken profilgerecht einbauen und </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">verdichten. Klassen 3 bis 5. Bauliche Anlagen </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">hinterfüllen und ggf. überschütten. Das Herstellen </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">des Planums wird gesondert berechnet. Boden </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">lagert innerhalb der Baustelle. Mittl. Länge des </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Förderweges bis 100 m. Abgerechnet wird nach Auftragsprofilen.  </span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Boden hinterfüllen, Bord</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item></Itemlist></BoQBody></BoQCtgy><BoQCtgy RNoPart="3" ID="id24"><LblTx><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Tragschichten o. B. Wege</span></p></LblTx><BoQBody><Itemlist><Item RNoPart="1" ID="id25"><Qty>3.000</Qty><QU>m3</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Frostschutzschicht nach ZTVT-StB 95/02 bzw. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">ZTV SoB-StB 04/07 in Fahrbahnnebenflächen </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">liefern, einbauen und lagenweise verdichten, </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">aus Baustoff Schotter-Splitt-Brechsand-Gemisch, </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Körnung 0/45, aus gebrochenem Hartgestein </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">oder Naturgestein, ohne Kalkstein, Schicht-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">dicke 25 cm, Verformungsmodul mind. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Ev2 80 MPa. Einbau in Streifen und Flächen. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Rand mit Neigung 1 : 1,5.</span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Frostschutzschicht D 25 cm Gehbahn</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="2" ID="id26"><Qty>16.000</Qty><QU>m3</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Frostschutzschicht nach ZTVT-StB 95/02 bzw. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">ZTV SoB-StB 04/07 in Fahrbahnen liefern, </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">einbauen und lagenweise verdichten, aus </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Baustoff Schotter-Splitt-Brechsand-Gemisch,</span><br/><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Körnung 0/45, aus gebrochenem Hartgestein </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">oder Naturgestein, ohne Kalkstein, Schicht-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">dicke 50 cm, Verformungsmodul mind. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">EV2 80 MPa. Einbau in Streifen und Flächen.</span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Frostschutzschicht D 30 cm Betonsteine</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="3" ID="id27"><Qty>8.000</Qty><QU>m3</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Ortbeton als Auflager unter den Betonsteinen,</span><br/><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Untergrund waagerecht, obere Betonfläche</span><br/><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">waagerecht, aus unbewehrtem Beton C 20/25,</span><br/><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Dicke 25 cm, liefern und einbauen.</span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Auflager Beton C 20/25 Betonsteine</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item></Itemlist></BoQBody></BoQCtgy><BoQCtgy RNoPart="4" ID="id28"><LblTx><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Pflasterarbeiten Wege</span></p></LblTx><BoQBody><Itemlist><Item RNoPart="1" ID="id29"><Qty>5.000</Qty><QU>m2</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Pflasterdecke nach Merkblatt für Flächenbefesti-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">gungen mit Pflaster- und Plattenbelägen, liefern </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">und verlegen, aus Betonsteinen, gefast, nach </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">DIN EN 1338, Höhe 8 cm, Erzeugnis Rechteck-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">stein, Farbe grau, Format 21 x 10,5 cm in Geh-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">bahnen, im Ellbogenverband, Bettung aus </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Splitt-Brechsand-Gemisch 2/5 mm, Dicke im </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">verdichteten Zustand 4 cm, Pflasterfugen ein-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">schlämmen mit Brechsand. Einschl. der er-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">forderlichen Rand- und Abschlußsteine. Steine </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">an Einbauten und Begrenzungen anpassen. </span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Betonpflaster liefern, einbauen</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="2" ID="id30"><Qty>5.000</Qty><QU>m2</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Pflasterdecke nach Merkblatt für Flächenbe-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">festigungen mit Pflaster- und Plattenbelägen, </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">gelagert auf der Baustelle auf Paletten, </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Förderweg bis 100 m, aus Pflastersteinen </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">aus Beton DIN EN 1338, Höhe 80 mm, </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Erzeugnis Rechteckstein, in Gehbahnen, </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">im Ellbogenverband, Bettung aus </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Splitt-Brechsand-Gemisch 2/5 mm, Dicke im </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">verdichteten Zustand 4 cm, Pflasterfugen ein-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">schlämmen mit Brechsand. Einschl. der er-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">forderlichen Rand- und Abschlußsteine. Steine </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">an Einbauten und Begrenzungen anpassen. </span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Betonpflaster wiederherstellen</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="3" ID="id31"><Qty>5.000</Qty><QU>m</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Anschlußarbeiten für vorbeschriebene Pflaster-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">decke als Zulage für das Herstellen von Schnitt-/</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Bruchkanten mit Motorschneidegerät und diamant-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">besetzter Trennscheibe.</span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Zul. Pflasterdecke Kante herstellen</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="4" ID="id32"><Qty>2.000</Qty><QU>m</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Bordstein aus Beton, DIN 483, Form T 8 x 25</span><br/><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">(80/250 mm), mit Vorsatzbeton, Zuschlag aus</span><br/><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">gebrochenem Hartgestein, liefern und verlegen</span><br/><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">mit Bettung und Rückenstütze, Bettung und</span><br/><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Rückenstütze DIN 18 318 aus Beton C 16/20,</span><br/><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Borde mit Ansicht engfugig in Geraden- und</span><br/><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Kurvenbereichen verlegen. Tiefbord versetzen </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">in Beton.</span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Bordstein Beton T 8x25 </span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="5" ID="id33"><Qty>1.000</Qty><QU>St</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Bordsteine auf Passmaß trennen. Bordsteine </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">quer schneiden. Bordsteine aus Beton, ca. 8</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">/25 bis 6/20 cm.</span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Bordsteine quer schneiden 8/25-6/20</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="6" ID="id34"><Qty>1.000</Qty><QU>St</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Bordsteine auf Passmaß trennen. Bordsteine </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">auf Gehrung schneiden. Bordsteine aus Beton, </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">ca. 8/25 bis 6/20 cm.</span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Bordsteine Gehrung schneiden 8/25-6/20</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item></Itemlist></BoQBody></BoQCtgy><BoQCtgy RNoPart="5" ID="id35"><LblTx><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Besondere Einbauten</span></p></LblTx><BoQBody><Itemlist><Item RNoPart="1" ID="id36"><Qty>6.000</Qty><QU>St</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Sitzstein als Blockelement aus Beton nach DIN EN </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">13198, mit mindestens 400 kg Zementgehalt je m3,</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">nachgewiesener Frost- und Tausalzwiderstand mit</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">einer Abwitterung von max. 1,5 kg/m2, Betongüte</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">C 30/37, Druckfestigkeit &#x3e; 37,0 N/mm2 (Mittel),</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Fase horizontal/vertikal 7/7, H x L x B: </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">55 x 200 x 40 cm, Oberfläche mit Natursteinvor-</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">satz, polargrau, Ansichtflächen kugelgestrahlt. </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Blockelement liefern und in Mörtelbett der </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Mörtelgruppe IIIa mit 10 cm Dicke versetzen.</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"/><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Angebotenes Fabrikat: .......................................</span></p></Text></DetailTxt><OutlineText><OutlTxt><TextOutlTxt><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span>Sitzstein L 2,00 m liefern, einbauen</span></p></TextOutlTxt></OutlTxt></OutlineText></CompleteText></Description></Item><Item RNoPart="2" ID="id37"><Qty>2.000</Qty><QU>St</QU><Description><CompleteText><DetailTxt><Text><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">Sitzstein als Blockelement aus Beton nach DIN EN </span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">13198, mit mindestens 400 kg Zementgehalt je m3,</span></p><p style="text-align:left;margin-top:0pt;margin-bottom:0pt;"><span style="font-family:Arial Narrow;font-size:12pt;Color:rgb(0,0,0);">nachgewiesener Frost- und Tausalzwiderstand mit</sp