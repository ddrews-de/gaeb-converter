        <QU>St</QU>
        <Description ID="R20260331080137254000001">
         <CompleteText>
          <DetailTxt>
           <Text>
            <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
             <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Teilnahme des Projektleiters an einem halbtägigen Ortstermin zur Bauberatung im Untersuchungsgebiet </span>
