    <BoQCtgy ID="AAAAAAAAIAJGAAAA" RNoPart="3">
     <LblTx>
      <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
       <span>Auswertung, Darstellung und Dokumentation</span>
      </p>
     </LblTx>
     <BoQBody>
      <Itemlist>
       <Item ID="AAAAAAAAIAJGBAKA" RNoPart="10">
        <Qty>29.481</Qty>
        <QU>km</QU>
        <Description ID="R20260227110852603000032">
         <CompleteText>
          <DetailTxt>
           <Text>
            <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
             <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Inversion der geoelektrischen Messwerte unter Berück- sichtigung der Elektrodenhöhen. </span>
             <br/>
             <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Darstellung der Ergebnisse als Widerstandsvertikalschnitte,</span>
            </p>
            <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
             <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Maßstab horizontal 1:1.000, vertikal 1:100. </span>
            </p>
           </Text>
          </DetailTxt>
          <OutlineText>
           <OutlTxt>
            <TextOutlTxt>
             <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
              <span>Inversion, Widerstandsvertikalschnitte</span>
             </p>
            </TextOutlTxt>
           </OutlTxt>
          </OutlineText>
          <!-- GAEB version used: 330 -->
          <!-- GAEB version used: 330 -->
         </CompleteText>
        </Description>
       </Item>
       <Item ID="AAAAAAAAIAJGCNMA" RNoPart="20">
        <LumpSumItem>Yes</LumpSumItem>
        <Qty>1.000</Qty>
        <QU>psch</QU>
        <Description ID="R20260227110852635000033">
         <CompleteText>
          <DetailTxt>
           <Text>
            <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
             <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Auswertung und Erstinterpretation der geoelektrischen Messsergebnisse anhand von Stützbohrungen aus der Baugrundvoruntersuchung.</span>
            </p>
            <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
             <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Darstellung eines Isopachenplans der deckstauenden Schichten auf Grundlage der geoelektrischen  Messungen unter Einbeziehung von Aufschlüssen aus der Baugrund- voruntersuchung. </span>
