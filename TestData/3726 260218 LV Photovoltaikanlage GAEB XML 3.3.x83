                  <Item ID="GW_4382072" RNoPart="11">
                    <Qty>2.000</Qty>
                    <QU>St</QU>
                    <CtlgAssign>
                      <CtlgID>GW_XX 501</CtlgID>
                      <CtlgCode>446</CtlgCode>
                    </CtlgAssign>
                    <Description ID="0a59abdf-ae72-405d-a4e5-5dcda8df5cec">
                      <CompleteText>
                        <DetailTxt>
                          <Text>
                            <p>
                              <span style="font-weight:bold;background:#FFFFFF;">AP Automatengehäuse 48 Teilungseinheiten</span>
                            </p>
                            <p>
                              <span style="font-weight:bold;background:#FFFFFF;">für oben genannten Überspannungsschutz an Hauseinführung</span>
                            </p>
                            <p>
                              <br />
                              <span style="color:#1D2022;">Isolierstoffgekapselte Niederspannungs-Schaltgerätekombination in Kastenbauform nach IEC 61439 -2 für Wandaufbau.</span>
                            </p>
                            <p>
                              <span style="color:#1D2022;">Gehäuse müssen zur Montage im Freien geeignet sein, es sind die klimatischen Ein- und Auswirkungen auf die Betriebsmittel zu beachten. </span>
                            </p>
                            <p>
                              <span style="color:#1D2022;">Kastenunterteile und -deckel aus schlagfestem Polycarbonat, halogen- und silikonfrei </span>
                            </p>
                            <p>
                              <span style="color:#1D2022;">Farbe RAL 7035, </span>
                            </p>
                            <p>
                              <span style="color:#1D2022;">Deckel transparent mit Schnellverschlüssen für Werkzeugbetätigung. </span>
                            </p>
                            <p>
                              <span style="color:#1D2022;">Brennverhalten gem. IEC 60695-2-11 </span>
                            </p>
                            <p>
                              <span style="color:#1D2022;">Glühdrahtprüfung + 960 °C. </span>
                            </p>
                            <p>
                              <span style="color:#1D2022;">Maximale Wasseraufnahme von 10 mg nach DIN 53473. </span>
                            </p>
                            <p>
                              <span style="color:#1D2022;">Schutzmaßnahme: Schutzisoliert (Schutzklasse II).</span>
                            </p>
                          </Text>
                        </DetailTxt>
                        <OutlineText>
                          <OutlTxt>
                            <TextOutlTxt>
                              <p>
                                <span style="font-weight:bold;background:#FFFFFF;">AP Automatengehäuse 48 Teilungseinheiten</span>
                              </p>
                            </TextOutlTxt>
                          </OutlTxt>
                        </OutlineText>
                      </CompleteText>
                    </Description>
                  </Item>
