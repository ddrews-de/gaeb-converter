                      <CompleteText>
                        <DetailTxt>
                          <Text>
                            <p>
                              <span style="font-weight:bold;background:#FFFFFF;">Solarleitung, 1 x 6 mm² vorh. Kabelrinne/Kanal</span>
                            </p>
                            <p />
                            <p>
                              <span style="background:#FFFFFF;">Halogenfreie strahlenvernetzte Solarleitung, 1 x 6 mm² als Ölflex Solar XL WP,</span>
                            </p>
                            <p>
                              <span style="background:#FFFFFF;"> </span>
                            </p>
                            <p>
                              <span style="background:#FFFFFF;">Witterungs- und UV-beständig nach EN 50618/ VDE 0283-618, ozonbeständig nach EN 50396; Querwasserdicht "AD8" nach IEC 60364-5-51/ HD 60364-5-51/ VDE 0100-510, IEC 62440 und EN 50525-2-21/ VDE 0285-525-2-21 bis 1 Meter Wassertiefe, halogenfrei und flammwidrig, besonders geeignet für PV Anlagen mit DC Systemspannungen bis max. 1.800 V gegen Erde, erdverlegbar ohne Schutzrohr, Bauartzertifiziert,feindrähtig, verzinnter Kupferleiter, geeignet für Umgebungstemperaturbereich gemäß EN 50618: -40°C bis +90°C, auf vorh. Kabelrinnen oder in offene Kanäle.</span>
                            </p>
                          </Text>
                        </DetailTxt>
                        <OutlineText>
                          <OutlTxt>
                            <TextOutlTxt>
                              <p>
                                <span style="font-weight:bold;background:#FFFFFF;">Solarleitung, 1 x 6 mm² vorh. Kabelrinne/Kanal</span>
                              </p>
                            </TextOutlTxt>
                          </OutlTxt>
                        </OutlineText>
                      </CompleteText>
                    </Description>
