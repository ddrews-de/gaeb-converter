                            <TextOutlTxt>
                              <p>
                                <span style="font-weight:bold;background:#FFFFFF;">NHXMH-J 7x2,5RE Bügelschellen</span>
                              </p>
                            </TextOutlTxt>
                          </OutlTxt>
                        </OutlineText>
                      </CompleteText>
