                            <p>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Größe		M 12 mm, l ca. 180 mm</span>
                            </p>
                            <p>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Bohrtiefe	ca. 12 cm</span>
                              <br/>
                            </p>
                            <p>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Abstand n. Angaben Tragwerksplanung</span>
                              <br/>
                            </p>
                          </Text>
                        </DetailTxt>
                        <OutlineText>
                          <OutlTxt>
                            <TextOutlTxt>
                              <p style="font-family:Arial;font-style:normal;font-weight:bold;font-size:10pt;color:rgb(0,0,0)">
                                <span>Injektionsbewehrung M12 </span>
                              </p>
                            </TextOutlTxt>
                          </OutlTxt>
