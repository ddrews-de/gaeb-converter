                  <Item ID="_42df5b38-7b67-4e7b-abce-d23d3e129524" RNoPart="80">
                    <Qty>145.000</Qty>
                    <QU>kg</QU>
                    <Description>
                      <CompleteText>
                        <DetailTxt>
                          <Text>
                            <p>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">für Fußplatten zu den Vorpositionen nach Angabe Statik mit Schweißnaht alle, bis a=5 mm zwischen Flansche, Blechen und auf Stahlträger, liefern und fachgerecht einbauen. Befestigung der Bleche auf STB-Boden mit Gewi in gesonderter Position. </span>
                              <br/>
                              <br/>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Größe		l / b / s    550/550/30 mm</span>
                              <br/>
                              <br/>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Alle Teile grundiert, Entrostung, Verschleifen, Bohrungen, Kantenfasen und Ausputzen der Schweißnähte sowie Ausgleichen, Schräg-, Gehrungsschnitte und Verschnitt  ist in EP mit einzurechnen.</span>
                              <br/>
                              <br/>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Schräg-, Gehrungsschnitte und Verschnitt werden nicht gesondert vergütet.</span>
                              <br/>
                            </p>
                          </Text>
                        </DetailTxt>
                        <OutlineText>
                          <OutlTxt>
                            <TextOutlTxt>
                              <p style="font-family:Arial;font-style:normal;font-weight:bold;font-size:10pt;color:rgb(0,0,0)">
                                <span>Flachstahl und Stahlbleche, S235 JR</span>
                              </p>
                            </TextOutlTxt>
                          </OutlTxt>
                        </OutlineText>
                      </CompleteText>
                    </Description>
                  </Item>
                  <Item ID="_3ebc8aed-8708-4efe-9f3f-9277f160fb07" RNoPart="90">
                    <Qty>12.000</Qty>
                    <QU>St</QU>
                    <Description>
                      <CompleteText>
                        <DetailTxt>
                          <Text>
                            <p>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Betonstahl DIN 488, BST 500 S (A); Stabstahl, zu den Vorpositionen nach Angabe Statik an Flansche, Blechen, Profilstahl, Rohre anschweißen. Abrechnung der Stahlmenge nach Position 3.4.10.</span>
                              <br/>
                              <br/>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Alle Teile grundiert, Befestigung, Entrostung, Verschleifen, Kantenfasen und Ausputzen der Schweißnähte sowie Ausgleichen ist in EP mit einzurechnen.</span>
                              <br/>
                              <br/>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Schräg-, Gehrungsschnitte und Verschnitt werden nicht gesondert vergütet.</span>
                              <br/>
                            </p>
                          </Text>
                        </DetailTxt>
                        <OutlineText>
                          <OutlTxt>
                            <TextOutlTxt>
                              <p style="font-family:Arial;font-style:normal;font-weight:bold;font-size:10pt;color:rgb(0,0,0)">
                                <span>Bügel aus Betonstabstahl, S235 J2</span>
                              </p>
                            </TextOutlTxt>
                          </OutlTxt>
                        </OutlineText>
                      </CompleteText>
                    </Description>
                  </Item>
                  <Item ID="_4371e503-fb94-4775-9be3-b2b6065fec33" RNoPart="100">
                    <Qty>8.000</Qty>
                    <QU>St</QU>
                    <Description>
                      <CompleteText>
                        <DetailTxt>
                          <Text>
                            <p>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">in vorbereiteten Anschlussflächen, als Lagesicherung, mit Gewindestange, U-Scheibe und selbstsichernder Mutter, nach Angaben Tragwerksplanung für Fußplatten, nach Zulassung und Herstellervorschrift Bohrungen herstellen, mit Injektionsmörtel einkleben und  verschrauben.</span>
                            </p>
                            <p/>
                            <p>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Produkt: Fischer FIS SB 390 S oder gleichwertig</span>
                              <br/>
                            </p>
                            <p>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">ang. Produkt:__________________________</span>
                            </p>
