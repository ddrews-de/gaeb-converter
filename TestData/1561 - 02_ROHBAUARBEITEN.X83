                                <span>Elementwand, Stahlbeton C 25/30, XC1, d = 24 cm</span>
                              </p>
                            </TextOutlTxt>
                          </OutlTxt>
                        </OutlineText>
                      </CompleteText>
                    </Description>
                  </Item>
