                                <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:bold;font-style:normal">Anschlussbewehrung</span>
                              </p>
                            </TextOutlTxt>
                          </OutlTxt>
                        </OutlineText>
                      </CompleteText>
                    </Description>
                  </Item>
