              <Item ID="_efedbbd1-4610-4a7e-a657-b2e3982de903" RNoPart="90">
                <Qty>1.000</Qty>
                <QU>St</QU>
                <Description>
                  <CompleteText>
                    <DetailTxt>
                      <Text>
                        <p>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">bauseits vorbereiteten Wasseranschluss im UG, Technik mit Messeinrichtung anschließen, außen aufstellen, betriebsfertig einrichten, vorhalten unterhalten, frostsicher verwahren und nach Abschluss der Arbeiten räumen; einschl. Erdarbeiten, sofern erforderlich. Das Wasser wird aus dem Netz des AG entnommen.</span>
                          <br/>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Bauwasseranschluss bestehende aus: </span>
                          <br/>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">- 1 Zähler </span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">- 2 Absperrventile</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">- 1 Entleerungshahn</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">- 1 Erdungsbrücke</span>
                          <br/>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Nennweite Hauptanschluss: 2 bis 2,5 Zoll</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Anzahl der Entnahmestellen: 2 Stück, davon 1 Stück am Gerüst der jeweils zu bearbeitenden Etage.</span>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Ventil und Schlauchverschraubung: min. 3 St., DN 20 bzw. 3/4 Zoll</span>
                        </p>
                        <p>
                          <br/>
                          <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Vorhaltezeit siehe gesonderte Position</span>
                          <br/>
                        </p>
                      </Text>
                    </DetailTxt>
                    <OutlineText>
                      <OutlTxt>
                        <TextOutlTxt>
                          <p style="font-family:Arial;font-style:normal;font-weight:bold;font-size:10pt;color:rgb(0,0,0)">
