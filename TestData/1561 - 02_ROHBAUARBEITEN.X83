                    <Qty>2.000</Qty>
                    <QU>m²</QU>
                    <Description>
                      <CompleteText>
                        <DetailTxt>
                          <Text>
                            <p>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">wie Decken, Wände, Stützen, Unterzüge, Brüstungen und Betonbalken waagrecht und senkrecht, aus Stahlbeton, im Bestand, in allen Geschoßen einschließlich Eckbohrungen / Kernlochbohrungen und aller Anfahrten. Gerät transportieren, mehrfach aufbauen, einrichten und umsetzen, abbauen. Anfallendes Wasser durch Schneidearbeiten ist aufzufangen und fachgerecht zu entsorgen.</span>
                              <br/>
                            </p>
                            <p>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Stärke:  ca. 24 cm - 30 cm</span>
                            </p>
                            <p/>
                          </Text>
