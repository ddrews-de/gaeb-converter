          <BoQBody>
            <BoQCtgy ID="_41abd167-0cdb-41e7-a949-c3fd1d926676" RNoPart="1">
              <LblTx>
                <p style="font-family:Arial;font-style:normal;font-weight:bold;font-size:10pt;color:rgb(0,0,0)">
                  <span>Vorarbeiten</span>
                </p>
              </LblTx>
              <BoQBody>
                <Itemlist>
                  <Item ID="_bd9f0459-72ce-43fc-aa97-94971b884d61" RNoPart="10">
                    <LumpSumItem>Yes</LumpSumItem>
                    <Qty>1.000</Qty>
                    <QU>psch</QU>
                    <Description>
                      <CompleteText>
                        <DetailTxt>
                          <Text>
                            <p>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">ist durch den Auftragnehmer unter Berücksichtigung der Angaben im Titel 2.2  &#x22;Rückbau und Verwertung&#x22; auszuarbeiten. Vor Ausführungsbeginn der Arbeiten sind dem Bauherrn und der Bauleitung die Unterlagen vollständig zu überreichen. Der Rückbau/Abbruch erfolgt in mehreren unabhängigen Abschnitten und Teilschritten, auch gewerkeübergreifend. Die Abbruchanweisungen ist für den gesamten Rückbau sowie die Benachrichtigung an die Bauberufsgenossenschaft(en), das Gewerbeaufsichtsamt, das Amt für Abfallrecht und den SiGeKo durch den AN selbst und rechtzeitig zu erledigen und in diese Position einzurechnen. Eine besondere Vergütung erfolgt nicht.</span>
                              <br/>
                            </p>
                          </Text>
                        </DetailTxt>
                        <OutlineText>
                          <OutlTxt>
                            <TextOutlTxt>
                              <p>
                                <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:bold;font-style:normal">Abbruch-/Rückbaukonzept</span>
                              </p>
                            </TextOutlTxt>
                          </OutlTxt>
                        </OutlineText>
                      </CompleteText>
                    </Description>
                  </Item>
                  <Item ID="_a89e2688-66c2-4655-a97f-ab7e5882b41e" RNoPart="20">
                    <Qty>20.000</Qty>
                    <QU>m²</QU>
                    <Description>
                      <CompleteText>
                        <DetailTxt>
                          <Text>
                            <p>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">bestehend aus einer Holzfaserabdeckplatte, 8mm, und Abdeckpappe &#x22;Milchtütenpapier, 200g/m² o. vglb. liefern, zum Schutz der Bodenbeläge mit Klebeband reversibel auf Böden staubdicht verkleben, während der Bauzeit vorhalten, unterhalten. Nach Gebrauch rückbauen, laden und gemäß den gesetzl. Vorgeben entsorgen.</span>
                              <br/>
                              <br/>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Einbauort:	Altbau DG, Treppenpodest, Klassenraum</span>
                              <br/>
                            </p>
