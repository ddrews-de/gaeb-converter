                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Tiefe ca. 20 cm</span>
                              <br/>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Abstand ca. alle 15 cm, zweireihig</span>
                              <br/>
                              <br/>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Aufmaß je Bohrung</span>
                              <br/>
                            </p>
                          </Text>
                        </DetailTxt>
                        <OutlineText>
                          <OutlTxt>
                            <TextOutlTxt>
                              <p style="font-family:Arial;font-style:normal;font-weight:bold;font-size:10pt;color:rgb(0,0,0)">
                                <span>Bewehrungsanschluss herstellen</span>
                              </p>
                            </TextOutlTxt>
                          </OutlTxt>
                        </OutlineText>
                      </CompleteText>
                    </Description>
                  </Item>
                  <Item ID="_df398c4a-e255-4b7b-957c-332c53c7a267" RNoPart="60">
                    <Qty>150.000</Qty>
                    <QU>kg</QU>
                    <Description>
                      <CompleteText>
                        <DetailTxt>
                          <Text>
                            <p>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Betonstahl, Stabstahl 500 S, für Anschlüsse, abschnittsweise, liefern, schneiden, biegen (auch an der Baustelle) lagern und verlegen, in allen vorkommenden Durchmessern. Abrechnungsgewicht nach den Stahllisten des Tragwerksplaners. Verschnitt wird nicht vergütet.</span>
                              <br/>
                            </p>
                            <p>
                              <span style="font-family:Arial;font-size:10pt;color:rgb(0,0,0);font-weight:normal;font-style:normal">Größe	alle, im wesentlichen d / l ca. 8 / 600 mm</span>
