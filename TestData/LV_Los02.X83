       <LblTx>
        <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
         <span>Peilstangensondierungen / Probensampler (PS)</span>
        </p>
       </LblTx>
       <BoQBody>
        <Itemlist>
         <Item ID="AAAAAAAAIAKHIJGI" RNoPart="10">
          <Qty>110.000</Qty>
          <QU>St</QU>
          <Description ID="R20260227133131280000139">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Peilstangensondierung ausführen.</span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Probenahme von Gewässersedimenten mittels Probensampler. </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Bestimmung der Sedimentmächtigkeit in Bereich der Altarme Ost und West sowie der Fließgewässer. </span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Tiefe Peilstangensondierung mindestens 1 m, maximal 2 m. </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Ausführung auf Querprofilen. </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">In diese Position sind erschwerte Bedingungen für die Zu- wegung und das Umsetzen zu den Sondierpunkten aufgrund der Lage in Waldgebieten einzukalkulieren.</span>
              </p>
             </Text>
            </DetailTxt>
            <OutlineText>
             <OutlTxt>
              <TextOutlTxt>
               <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
                <span>Peilstangensondierung / Probensampler</span>
               </p>
              </TextOutlTxt>
             </OutlTxt>
            </OutlineText>
            <!-- GAEB version used: 330 -->
            <!-- GAEB version used: 330 -->
           </CompleteText>
          </Description>
         </Item>
        </Itemlist>
       </BoQBody>
      </BoQCtgy>
      <BoQCtgy ID="AAAAAAAAIAKHKFNI" RNoPart="7">
       <LblTx>
        <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
         <span>Probenahmeschürfe (SCH)</span>
        </p>
       </LblTx>
       <BoQBody>
        <Itemlist>
         <Item ID="AAAAAAAAIAKHLGOA" RNoPart="10">
          <Qty>77.000</Qty>
          <QU>St</QU>
          <Description ID="R20260227133131316000141">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Herstellen eines Probenahmeschurfs. </span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Abgrabungstiefe mindestens 0,70 m bis 1,25 m nach Vorgabe des geotechnischen Sachverständigen.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Boden zur Wiederverwendung seitlich lagern.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Schurfdokumentation anfertigen.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Schurf mit seitlich gelagertem Boden gemäß angetroffener Schichtenabfolge verfüllen.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Verdichten und Wiederherstellen des Ursprungszustandes.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Die Anforderungen der DIN 4124 sind zu beachten.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Probenentnahme wird gesondert vergütet.</span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">In diese Position sind erschwerte Bedingungen für die Zu- wegung und das Umsetzen zu den Schurfstellen aufgrund der teilweisen Lage in Waldgebieten einzukalkulieren.</span>
              </p>
             </Text>
            </DetailTxt>
            <OutlineText>
             <OutlTxt>
              <TextOutlTxt>
               <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
                <span>Herstellen eines Probenahmeschurfes</span>
               </p>
              </TextOutlTxt>
             </OutlTxt>
