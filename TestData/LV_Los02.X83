             </OutlTxt>
            </OutlineText>
            <!-- GAEB version used: 330 -->
            <!-- GAEB version used: 330 -->
           </CompleteText>
          </Description>
         </Item>
         <Item ID="AAAAAAAAIANIBAAA" RNoPart="20">
          <Qty>1.000</Qty>
          <QU>St</QU>
          <Description ID="R20260313140520800000001">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">wie Pos. 4.1.10, jedoch </span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Umsetzen von Bauwerksstandort zu Bauwerksstandort,</span>
