      <BoQCtgy ID="AAAAAAAAIAKJIHMI" RNoPart="4">
       <LblTx>
        <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
         <span>Hydrologische Pumpversuche (PV)</span>
        </p>
       </LblTx>
       <BoQBody>
        <Itemlist>
         <Remark ID="AAAAAAAAIAKJJIGI">
          <Description ID="R20260227133130014000103">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Betreiben einer Pumpversuchseinrichtung, </span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Einsatz einer regelbaren Pumpe mit entsprechenden Schläuchen und Rohrleitungen, </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">max. 3 % Konstanz in Bezug auf die Förderleistung. </span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Förderleistung max. 25m3/h, abzuleiten aus dem  jeweiligen Klarpumpversuch.</span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Ableitung und Einleitung des abgepumpten Grundwassers in einen Vorfluter bzw. Versickerung auf geeigneten Flächen.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Entfernung zum Einleitpunkt bis 100 m. </span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Die Hinweise in der Leistungsbeschreibung, Kap. 3.13, sind zu beachten.</span>
              </p>
             </Text>
            </DetailTxt>
            <OutlineText>
             <OutlTxt>
              <TextOutlTxt>
               <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
                <span>Vorbemerkungen</span>
               </p>
              </TextOutlTxt>
             </OutlTxt>
            </OutlineText>
            <!-- GAEB version used: 330 -->
            <!-- GAEB version used: 330 -->
           </CompleteText>
          </Description>
         </Remark>
         <Item ID="AAAAAAAAIAKFGGHI" RNoPart="10">
          <Qty>10.000</Qty>
          <QU>St</QU>
          <Description ID="R20260310101339449000002">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Auf-/Abbauen sowie Umsetzen der Pumpversuchseinrichtung und sämtlicher für die Versuchsausführung erforderlicher Gerätschaften und Materialien. </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Einbautiefe der Pumpe max. 10 m u. GOK. </span>
              </p>
             </Text>
            </DetailTxt>
            <OutlineText>
             <OutlTxt>
              <TextOutlTxt>
               <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
                <span>Auf-/Abbau und Umsetzen</span>
               </p>
              </TextOutlTxt>
             </OutlTxt>
            </OutlineText>
            <!-- GAEB version used: 330 -->
            <!-- GAEB version used: 330 -->
           </CompleteText>
          </Description>
         </Item>
         <Item ID="AAAAAAAAIAKJKFOI" RNoPart="20">
          <Qty>10.000</Qty>
          <QU>St</QU>
          <Description ID="R20260227133130014000104">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Hydrologischen Pumpversuch ausführen und auswerten </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">(kf-Wert). </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Durchführung und Dokumentation nach DVGW-Arbeitsblatt </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">W 111. </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Versuchsdurchführung mit einer Pumpstufe. </span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Förderzeitraum mind. 6 Stunden, </span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Beobachtung GW-Wiederanstieg bis zum Erreichen </span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">des Ausgangsniveaus, max. 3 Stunden. </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Versuchsmessstelle DN 125 und 2 GW-Beobachtungs-</span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">messtellen GWM DN 80 für Ausrüstung mit Datenlogger. </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Messgeräte vorhalten und betreiben. </span>
              </p>
             </Text>
            </DetailTxt>
            <OutlineText>
             <OutlTxt>
              <TextOutlTxt>
               <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
                <span>Hydrologischer Pumpversuch (PV)</span>
               </p>
              </TextOutlTxt>
             </OutlTxt>
            </OutlineText>
            <!-- GAEB version used: 330 -->
            <!-- GAEB version used: 330 -->
           </CompleteText>
          </Description>
         </Item>
        </Itemlist>
       </BoQBody>
