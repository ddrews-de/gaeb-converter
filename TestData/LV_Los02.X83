         <Item ID="AAAAAAAAIANHKAAA" RNoPart="60">
          <Qty>100.000</Qty>
          <QU>m</QU>
          <Description ID="R20260302144548082000037">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Kernbohrung nach DIN EN ISO 22475-1 gemäß Bau- beschreibung und Lageplan ausführen.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Homogenbereiche nach Kap. 2.5.3 Baubeschreibung.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Bohrverfahren = Trockenbohrverfahren mit Einbringen der Bohrkerne in Kernliner und Kernkisten.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Endtiefe der Gesamtbohrung 15 bis 30 m. </span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Enddurchmesser der Gesamtbohrung mind. 273 mm für temporären Ausbau zum Versuchsbrunnen DN 125, </span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Verrohrung bis zur Endtiefe einbringen und nach Beendigung der Bohrung ziehen.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Bohrgut aus der Nachräumung nach Bodenarten getrennt seitlich lagern.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Die Entnahme von ungestörten Proben (Stutzen) sowie das Einbringen der Bohrkerne in Kernliner und Kernkisten wird gesondert vergütet. </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Führen des Feldberichtes / Schichtenverzeichnisses wird nicht gesondert vergütet.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Bohrbereich 0 bis 10 m.</span>
              </p>
             </Text>
            </DetailTxt>
            <OutlineText>
             <OutlTxt>
              <TextOutlTxt>
               <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
                <span>Kernbohrung ausführen, 273 mm, Bohrbereich 0 bis 10 m</span>
               </p>
              </TextOutlTxt>
             </OutlTxt>
            </OutlineText>
            <!-- GAEB version used: 330 -->
            <!-- GAEB version used: 330 -->
           </CompleteText>
          </Description>
         </Item>
