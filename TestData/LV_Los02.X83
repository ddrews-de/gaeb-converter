         <Item ID="AAAAAAAAIAJKIFNI" RNoPart="60">
          <Qty>2235.000</Qty>
          <QU>m</QU>
          <Description ID="R20260227133129155000073">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Drucksondierung nach DIN EN ISO 22476-1 gemäß Baubeschreibung und Lageplan ausführen.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Homogenbereiche nach Kap. 2.5.3 Baubeschreibung.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Kontinuierliche Messung, Aufzeichnung, Korrektur sowie grafische Darstellung von Sondierlänge, Spitzenwiderstand, Mantelreibung, Reibungsverhältnis, Porenwasserdruck und Neigung der Sondierspitze.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Angaben zur Gesamtkraft.</span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Endtiefe 15 bis 40 m.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Sondiertiefe 0 bis 20 m.</span>
              </p>
             </Text>
            </DetailTxt>
            <OutlineText>
             <OutlTxt>
              <TextOutlTxt>
               <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
                <span>Drucksondierung ausführen, Tiefe 0 - 20 m</span>
               </p>
              </TextOutlTxt>
             </OutlTxt>
            </OutlineText>
            <!-- GAEB version used: 330 -->
            <!-- GAEB version used: 330 -->
           </CompleteText>
          </Description>
