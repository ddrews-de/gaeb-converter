         <Item ID="AAAAAAAAIANLGPOA" RNoPart="60">
          <Qty>2558.000</Qty>
          <QU>m</QU>
          <Description ID="R20260227133130936000129">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Kleinrammbohrung nach DIN EN ISO 22475-1 gemäß Baubeschreibung und Lageplan ausführen.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Homogenbereiche nach Kap. 2.5.3 Baubeschreibung.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Endtiefe der Gesamtbohrung 2,00 m bis 7,00 m.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Durchmesser der Bohrung </span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">- bis 2,00 m Bohrtiefe mind. 60 - 80 mm, </span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">- bis 5,00 m Bohrtiefe mind. 36 - 50 mm, </span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">- über 5,00 m Bohrtiefe mind. 30 - 36 mm.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Bohrgut nach Bodenarten getrennt seitlich lagern.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Grundwasseranschnitt beim Ausführen der Bohrarbeiten sowie die Änderung des Wasserspiegels nach Erreichen der Endtiefe feststellen und protokollieren.</span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Führen des Feldberichtes wird nicht gesondert vergütet.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Probenentnahme Einzelproben wird gesondert vergütet.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Verfüllen wird gesondert vergütet.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Bohrbereich 0,00 bis 5,00 m.</span>
              </p>
             </Text>
            </DetailTxt>
            <OutlineText>
             <OutlTxt>
              <TextOutlTxt>
               <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
                <span>Kleinbohrung ausführen, 0 bis 5 m</span>
               </p>
              </TextOutlTxt>
             </OutlTxt>
            </OutlineText>
            <!-- GAEB version used: 330 -->
            <!-- GAEB version used: 330 -->
           </CompleteText>
          </Description>
         </Item>
