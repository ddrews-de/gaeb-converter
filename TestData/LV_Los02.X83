      <BoQCtgy ID="AAAAAAAAIAJGJFEI" RNoPart="4">
       <LblTx>
        <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
         <span>Bauvermessung</span>
        </p>
       </LblTx>
       <BoQBody>
        <Itemlist>
         <Item ID="AAAAAAAAIAJGHGMA" RNoPart="10">
          <Qty>931.000</Qty>
          <QU>St</QU>
          <Description ID="R20260302113537085000025">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Bauvorbereitende Vermessung, </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Abstecken eines Bohr- und Sondieransatzpunktes im Gelände auf Grundlage einer Koordinatenliste des Objektplaners in Vorbereitung der Kampfmittelfreimessung.</span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Die Absteckung der Ansatzpunkte erfolgt im Beisein des geotechnischen Sachverständigen.</span>
              </p>
             </Text>
            </DetailTxt>
            <OutlineText>
             <OutlTxt>
              <TextOutlTxt>
               <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
                <span>Abstecken Ansatzpunkt</span>
               </p>
              </TextOutlTxt>
             </OutlTxt>
            </OutlineText>
            <!-- GAEB version used: 330 -->
            <!-- GAEB version used: 330 -->
           </CompleteText>
          </Description>
         </Item>
         <Item ID="AAAAAAAAIAJMELHI" RNoPart="20">
          <Qty>1174.000</Qty>
          <QU>St</QU>
          <Description ID="R20260227133128874000063">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Bauausführungsvermessung, </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Einmessen eines Bohr-, Schurf- oder Sondieransatzpunktes nach Lage und Höhe.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Lagebezug: ETRS89, UTM32 (LS 489),</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Höhenbezug: DHHN2016 (HS 170). </span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Lage- und Höhengenauigkeit: </span>
               <span style="font-family:Symbol;font-size:10pt;Color:rgb(0,0,0);">±</span>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);"> 2 cm.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Koordinaten- und Höhenangaben in die geotechnische Aufschlussdokumentation einarbeiten. </span>
              </p>
             </Text>
            </DetailTxt>
            <OutlineText>
             <OutlTxt>
              <TextOutlTxt>
               <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
                <span>Einmessen geotechnischer Aufschluss</span>
               </p>
              </TextOutlTxt>
             </OutlTxt>
            </OutlineText>
            <!-- GAEB version used: 330 -->
            <!-- GAEB version used: 330 -->
           </CompleteText>
          </Description>
         </Item>
        </Itemlist>
       </BoQBody>
      </BoQCtgy>
      <BoQCtgy ID="AAAAAAAAIAJGLEII" RNoPart="5">
       <LblTx>
        <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
         <span>Bauvorbereitung</span>
        </p>
       </LblTx>
       <BoQBody>
        <Itemlist>
         <Item ID="AAAAAAAAIAJMBAOA" RNoPart="10">
          <LumpSumItem>Yes</LumpSumItem>
          <Qty>1.000</Qty>
          <QU>psch</QU>
          <Description ID="R20260227133128795000061">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Operative Information und Abstimmung mit Eigentümern, Pächtern sowie Bewirtschaftern der von den geotechnischen Feldarbeiten betroffenen Grundstücke. </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Zu kalkulieren sind ca. 30 Eigentümer/Pächter.</span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Übergabe der Kontaktdaten durch den AG. </span>
              </p>
             </Text>
            </DetailTxt>
            <OutlineText>
             <OutlTxt>
              <TextOutlTxt>
               <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
                <span>Abstimmung mit Eigentümern/Pächtern/Bewirtschaftern</span>
               </p>
              </TextOutlTxt>
             </OutlTxt>
            </OutlineText>
            <!-- GAEB version used: 330 -->
            <!-- GAEB version used: 330 -->
           </CompleteText>
          </Description>
         </Item>
         <Item ID="AAAAAAAAIAJMIGGI" RNoPart="20">
          <Qty>9000.000</Qty>
          <QU>m2</QU>
          <Description ID="R20260227133128952000065">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Ausführung von Freischnitt- und Fällarbeiten im Bereich der Zuwegungen und Arbeitsstellen. </span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Position beinhaltet das Freischneiden von bodennahem Aufwuchs und Ästen sowie die Beseitigung von schwachen Laubbäumen bis 25 cm Stammdurchmesser. </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Die zu beseitigenden Bäume werden im Vorfeld durch den AG mit den Eigentümern und Bewirtschaftern sowie der unteren Naturschutzbehörde abgestimmt. </span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Durchfahrtsbreite je nach Erfordernis, max. 3,50 m.</span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Flächen für Arbeitsstellen max. 10x15 m. </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Schnittgut soll zu Zwecken des bauzeitlichen Bodenschutzes verwendet werden und vor Ort verbleiben. </span>
              </p>
             </Text>
            </DetailTxt>
            <OutlineText>
             <OutlTxt>
              <TextOutlTxt>
               <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
                <span>Freischnitt- und Fällarbeiten</span>
               </p>
              </TextOutlTxt>
             </OutlTxt>
            </OutlineText>
            <!-- GAEB version used: 330 -->
            <!-- GAEB version used: 330 -->
           </CompleteText>
          </Description>
         </Item>
         <Item ID="AAAAAAAAIAJMGJDI" RNoPart="30">
          <Qty>3.000</Qty>
          <QU>St</QU>
          <Description ID="R20260227133128920000064">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Vorschachten zum Aufsuchen von erdverlegten Leitungen.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Ausführung als Handschachtung bei unklarem Leitungs- bestand.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Schachtungstiefe bis 1,50 m, ohne Verbau.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Boden zur Wiederverwendung seitlich lagern. </span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Vorschachtung mit seitlich gelagertem Boden verfüllen.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Verdichten und Wiederherstellen des Ursprungszustandes.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Vorschriften der Ver- und Entsorgungsunternehmen beachten.</span>
              </p>
             </Text>
            </DetailTxt>
            <OutlineText>
             <OutlTxt>
              <TextOutlTxt>
               <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
                <span>Vorschachten</span>
               </p>
              </TextOutlTxt>
             </OutlTxt>
            </OutlineText>
            <!-- GAEB version used: 330 -->
            <!-- GAEB version used: 330 -->
           </CompleteText>
          </Description>
         </Item>
         <Item ID="AAAAAAAAIAJMCONI" RNoPart="40">
          <LumpSumItem>Yes</LumpSumItem>
          <Qty>1.000</Qty>
          <QU>psch</QU>
          <Description ID="R20260227133128842000062">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Maßnahmen zur Verkehrssicherung an Arbeitsstellen im Bereich des öffentlichen Verkehrsraums gemäß den Bestimmungen der verkehrrechtlichen Anordnungen für die Dauer der Erkundungsarbeiten (Teilsperrung bei Arbeitsstellen von kürzerer Dauer).</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Vorhalten, Auf- und Abbauen sowie Umsetzen von Arbeitstelle zu Arbeitstelle.</span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">- Straße &#x22;Silberberg&#x22; in Zöschen (Stadt Leuna),</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">- &#x22;Luppeweg&#x22; in Wallendorf (Stadt Leuna).</span>
              </p>
             </Text>
            </DetailTxt>
            <OutlineText>
             <OutlTxt>
              <TextOutlTxt>
               <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
                <span>Verkehrssicherungsmaßnahmen</span>
               </p>
              </TextOutlTxt>
             </OutlTxt>
            </OutlineText>
            <!-- GAEB version used: 330 -->
            <!-- GAEB version used: 330 -->
