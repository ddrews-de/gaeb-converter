         <Item ID="AAAAAAAAIANJJIBI" RNoPart="170">
          <Qty>565.000</Qty>
          <QU>m</QU>
          <Description ID="R20260227133129749000093">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Einbringen des Bohrkerns in Kernliner aus PVC, </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Durchmesser 100 mm, Kernlänge 1,00 m. </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Auftrennen der Kernhüllen in Abstimmung mit dem geotechnischen Sachverständigen. </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Entleerung und Entsorgung der Kernhüllen und des Bohrkerns erfolgt durch den AN nach Freigabe durch den geotechnischen Sachverständigen. </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Das Liefern und Beschriften der Kernhüllen wird nicht gesondert vergütet. </span>
              </p>
             </Text>
            </DetailTxt>
