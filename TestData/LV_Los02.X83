      <BoQCtgy ID="AAAAAAAAIAKGLJMI" RNoPart="5">
       <LblTx>
        <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
         <span>Kleinbohrungen (RKB)</span>
        </p>
       </LblTx>
       <BoQBody>
        <Itemlist>
         <Remark ID="AAAAAAAAIAKGMKLI">
          <Description ID="R20260227133130686000123">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Bohrgeräte nach Wahl des AN.</span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Muss eine Kleinbohrung vor Erreichen der vorgesehenen Endtiefe wegen eines Hindernisses abgebrochen und in unmittelbarer Nähe neu angesetzt werden, wird das Umsetzen bis zu einer Entfernung von 10 m nicht gesondert gesondert vergütet.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Das Umsetzen erfolgt in Absprache mit dem geotechnischen Sachverständigen.</span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Die Hinweise in der Leistungsbeschreibung, Kap. 3.15, sind zu beachten.</span>
              </p>
             </Text>
            </DetailTxt>
            <OutlineText>
             <OutlTxt>
              <TextOutlTxt>
               <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
                <span>Vorbemerkung</span>
               </p>
              </TextOutlTxt>
             </OutlTxt>
            </OutlineText>
            <!-- GAEB version used: 330 -->
            <!-- GAEB version used: 330 -->
           </CompleteText>
          </Description>
         </Remark>
         <Item ID="AAAAAAAAIAKGNIDI" RNoPart="10">
          <Qty>543.000</Qty>
          <QU>St</QU>
          <Description ID="R20260227133130686000124">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Kleinbohrausrüstung von Ansatzpunkt zu Ansatzpunkt umsetzen und einrichten. </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Umsetzen innerhalb von Erkundungsquerprofilen, Deich- und Verkehrswegeabschnitten, Altarmen und Bauwerksstandorten. </span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Transportentfernung über 10 m bis 100 m.</span>
              </p>
             </Text>
            </DetailTxt>
            <OutlineText>
             <OutlTxt>
              <TextOutlTxt>
               <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
                <span>Bohrausrüstung umsetzen bis 100 m</span>
               </p>
              </TextOutlTxt>
             </OutlTxt>
            </OutlineText>
            <!-- GAEB version used: 330 -->
            <!-- GAEB version used: 330 -->
           </CompleteText>
          </Description>
         </Item>
