      <BoQCtgy ID="AAAAAAAAIAKEHCIA" RNoPart="8">
       <LblTx>
        <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
         <span>Probenentnahme</span>
        </p>
       </LblTx>
       <BoQBody>
        <Itemlist>
         <Remark ID="AAAAAAAAIAKEIDCI">
          <Description ID="R20260227133131481000150">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Die nachstehenden Positionen zur Probenentnahme verstehen sich inkl. Liefern, Befüllen und Beschriften der jeweiligen Probenbehältnisse sowie Entnehmen, Behandeln, Trans- portieren und Aufbewahren der Proben.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Außerdem sind Probenentnahmeprotokolle zu führen.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Die Hinweise in der Leistungsbeschreibung sind zu beachten.</span>
              </p>
             </Text>
            </DetailTxt>
            <OutlineText>
             <OutlTxt>
              <TextOutlTxt>
               <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
                <span>Vorbemerkung</span>
               </p>
              </TextOutlTxt>
             </OutlTxt>
            </OutlineText>
            <!-- GAEB version used: 330 -->
            <!-- GAEB version used: 330 -->
           </CompleteText>
          </Description>
         </Remark>
         <Item ID="AAAAAAAAIAKEJAKI" RNoPart="10">
          <Qty>30.000</Qty>
          <QU>St</QU>
          <Description ID="R20260227133131481000151">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Entnehmen einer Sonderprobe aus einer Kernbohrung.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Probenahmeverfahren der Kategorie A  nach </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">DIN EN ISO 22475-1, Güteklasse 1-2.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Homogenbereiche A2 und BB2 nach Baubeschreibung.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Entnahme mittels dünnwandigem, offenen Entnahmegerät </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">(OS-T/W),  Durchmesser 100 mm, Länge mindestens 250 mm.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Entnahmetiefe bis 20 m unter GOK.</span>
              </p>
             </Text>
            </DetailTxt>
            <OutlineText>
             <OutlTxt>
              <TextOutlTxt>
               <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
                <span>Entnehmen einer Bodenprobe, Entnahmekategorie A, Bohrung</span>
               </p>
              </TextOutlTxt>
             </OutlTxt>
            </OutlineText>
            <!-- GAEB version used: 330 -->
            <!-- GAEB version used: 330 -->
           </CompleteText>
          </Description>
         </Item>
         <Item ID="AAAAAAAAIAKELBHA" RNoPart="20">
          <Qty>20.000</Qty>
          <QU>St</QU>
          <Description ID="R20260227133131564000152">
           <CompleteText>
            <DetailTxt>
             <Text>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Entnehmen einer ungestörten Bodenprobe aus einem Probe- nahmeschurf.</span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Probenahmeverfahren der Kategorie A nach </span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">DIN EN ISO 22475-1, Güteklasse 1-2.</span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Homogenbereiche A2 und BB2 nach Baubeschreibung.</span>
              </p>
              <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Entnahmetiefe bis 1,25 m unter GOK. Entnahme mittels Stutzen. Durchmesser mind. 100 mm. </span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Es werden nur vollständig gefüllte Stutzen vergütet.</span>
               <br/>
               <span style="font-family:Arial;font-size:10pt;Color:rgb(0,0,0);">Die Herstellung des Probenahmeschurfes wird gesondert vergütet (Pos. 4.7.10).</span>
              </p>
             </Text>
            </DetailTxt>
            <OutlineText>
             <OutlTxt>
              <TextOutlTxt>
               <p style="text-align:left;margin-top:0pt;margin-bottom:0pt;">
                <span>Entnehmen einer Bodenprobe, Entnahmekategorie A, Schurf</span>
               </p>
              </TextOutlTxt>
             </OutlTxt>
            </OutlineText>
            <!-- GAEB version used: 330 -->
            <!-- GAEB version used: 330 -->
