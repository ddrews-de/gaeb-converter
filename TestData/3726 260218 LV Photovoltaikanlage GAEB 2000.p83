\headery567\footery567\pgwsxn46828\pghsxn66274\marglsxn0\margtsxn0\margrsxn0\margbsxn0\pgbrdropt32\pard\ltrpar\s17\itap0\nowidctlpar\qc\li0\ri0\lin0\rin0\tx850\tx1701\tx2522\tx4252\tx5102\tx5953\tx6803\tx7654\tx8504\tx9354\tx10205\tx11055\tx11906\plain\rtlch\af0\afs18\alang1031\ab\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\b L E I S T U N G S V E R Z E I C H N I S\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\par\pard\ltrpar\s17\itap0\nowidctlpar\ql\li0\ri0\lin0\rin0\tx850\tx1701\tx2551\tx3402\tx4252\tx5102\tx5953\tx6803\tx7654\tx8504\tx9354\tx10205\tx11055\tx11906\par\par\par\par\pard\ltrpar\s17\itap0\nowidctlpar\ql\li1587\ri0\lin1587\rin0\tx850\tx1701\tx2551\tx3402\tx4252\tx5102\tx5953\tx6803\tx7654\tx8504\tx9354\tx10205\tx11055\tx11906\plain\rtlch\af0\afs18\alang1031\ab\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\b Gewerk:\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031              \tab\tab 442 Photovoltaikanlagen\par\par\par\par\plain\rtlch\af0\afs18\alang1031\ab\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\b Projekt: \plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031             \tab\tab 3726 Neubau Gescherweg M\loch\af0\dbch\af0\hich\f0\'fc\hich\af0\dbch\af0\loch\f0 nster\tab\tab\tab\tab\tab\tab\tab\tab\tab Gescherweg 84a\tab\tab\tab\tab\tab\tab\tab\tab\tab\tab\tab 48161 M\loch\af0\dbch\af0\hich\f0\'fc\hich\af0\dbch\af0\loch\f0 nster\par\par\par\par\plain\rtlch\af0\afs18\alang1031\ab\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\b Bauherr:\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\tab\tab\tab Studierendenwerk M\loch\af0\dbch\af0\hich\f0\'fc\hich\af0\dbch\af0\loch\f0 nster\tab\tab\tab\tab\tab\tab\tab\tab\tab\tab Bismarckallee 5 \tab\tab\tab\tab\tab\tab\tab\tab\tab\tab\tab 48151 M\loch\af0\dbch\af0\hich\f0\'fc\hich\af0\dbch\af0\loch\f0 nster\par\par\par\par\plain\rtlch\af0\afs18\alang1031\ab\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\b Fachingenieur:\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\tab\tab Schr\loch\af0\dbch\af0\hich\f0\'f6\hich\af0\dbch\af0\loch\f0 der & Partner\par\tab\tab\tab\tab Beratende Ingenieure VBI f\loch\af0\dbch\af0\hich\f0\'fc\hich\af0\dbch\af0\loch\f0 r Elektrotechnik\par\tab\tab\tab\tab Schillerstra\loch\af0\dbch\af0\hich\f0\'df\hich\af0\dbch\af0\loch\f0 e 81\par\tab\tab\tab\tab 33609 Bielefeld\par\par\par\par\par\par\par\par\par\par\par\pard\ltrpar\s17\itap0\nowidctlpar\ql\li1700\ri0\lin1700\rin0 Bieter:                                               \tab '................................................'\par\par\par Angebotssumme netto zur Abgabe:\tab '................................................'\par\par\par gew\loch\af0\dbch\af0\hich\f0\'e4\hich\af0\dbch\af0\loch\f0 hrter Nachlass in %:\tab\tab '................................................'\par\par\par Nachlassumme:\tab\tab\tab '................................................'\par\par\par Gesamtsumme inkl. Nachlass netto:\tab '................................................'\par\par\par + 19% Mehrwertsteuer:\tab\tab '................................................'\par\par\par Gesamtsumme brutto:\tab\tab '................................................'\par\pard\ltrpar\s17\itap0\nowidctlpar\ql\li1587\ri0\lin1587\rin0\tx850\tx1701\tx2551\tx3402\tx4252\tx5102\tx5953\tx6803\tx7654\tx8504\tx9354\tx10205\tx11055\tx11906\par\pard\ltrpar\s17\itap0\nowidctlpar\ql\li0\ri0\lin0\rin0\tx850\tx1701\tx2551\tx3402\tx4252\tx5102\tx5953\tx6803\tx7654\tx8504\tx9354\tx10205\tx11055\tx11906 }[end]
