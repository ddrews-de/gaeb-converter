\headery567\footery567\pgwsxn46828\pghsxn66274\marglsxn0\margtsxn0\margrsxn0\margbsxn0\pgbrdropt32\pard\ltrpar\s17\itap0\nowidctlpar\ql\li0\ri0\lin0\rin0\tx850\tx1701\tx2551\tx3402\tx4252\tx5102\tx5953\tx6803\tx7654\tx8504\tx9354\tx10205\tx11055\tx11906\plain\rtlch\af0\afs18\alang1031\ab\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\b Unterverteiler PV Anlage f\loch\af0\dbch\af0\hich\f0\'fc\hich\af0\dbch\af0\loch\f0 r Montage auf Flachdachst\loch\af0\dbch\af0\hich\f0\'e4\hich\af0\dbch\af0\loch\f0 nder, IP 65, komplett f\loch\af0\dbch\af0\hich\f0\'fc\hich\af0\dbch\af0\loch\f0 r ca. 45kWp\par\par best\loch\af0\dbch\af0\hich\f0\'fc\hich\af0\dbch\af0\loch\f0 ckt mit\par\par 3x RCD TYP A 300mA \par 3x LS Schalter B40A/3\par 2x LS Schalter B16A/1\par 1x D02 63A Sicherungselement\tab\par 1x AC-\loch\af0\dbch\af0\hich\f0\'dc\hich\af0\dbch\af0\loch\f0 berspannungsschutz TYP 2+3\par 2x Klemmstein\par\plain\rtlch\af0\afs18\alang0\ab\acf2\aexpnd1\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\b\cf2\cb3\chshdng0\chcfpat0\chcbpat3\expnd1\expndtw7 2x Automatengeh\loch\af0\dbch\af0\hich\f0\'e4\hich\af0\dbch\af0\loch\f0 use\plain\rtlch\af0\afs18\alang0\acf2\aexpnd1\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\cf2\cb3\chshdng0\chcfpat0\chcbpat3\expnd1\expndtw7\par\par je St\loch\af0\dbch\af0\hich\f0\'fc\hich\af0\dbch\af0\loch\f0 ck:\par\par H\loch\af0\dbch\af0\hich\f0\'f6\hich\af0\dbch\af0\loch\f0 he: 600mm  \par Breite: 300mm  \par Tiefe: 170mm\par\par Kastenunterteile und -deckel aus schlagfestem Polycarbonat, halogen- und silikonfrei \par Farbe RAL 7035,\par Deckel transparent mit Schnellverschl\loch\af0\dbch\af0\hich\f0\'fc\hich\af0\dbch\af0\loch\f0 ssen f\loch\af0\dbch\af0\hich\f0\'fc\hich\af0\dbch\af0\loch\f0 r Werkzeugbet\loch\af0\dbch\af0\hich\f0\'e4\hich\af0\dbch\af0\loch\f0 tigung. \par Brennverhalten gem. IEC 60695-2-11 \par Gl\loch\af0\dbch\af0\hich\f0\'fc\hich\af0\dbch\af0\loch\f0 hdrahtpr\loch\af0\dbch\af0\hich\f0\'fc\hich\af0\dbch\af0\loch\f0 fung + 960 \loch\af0\dbch\af0\hich\f0\'b0\hich\af0\dbch\af0\loch\f0 C. \par Maximale Wasseraufnahme von 10 mg nach DIN 53473. Schutzma\loch\af0\dbch\af0\hich\f0\'df\hich\af0\dbch\af0\loch\f0 nahme: Schutzisoliert (Schutzklasse II). \par IP Schutzart IP65\par Geeignet f\loch\af0\dbch\af0\hich\f0\'fc\hich\af0\dbch\af0\loch\f0 r den Au\loch\af0\dbch\af0\hich\f0\'df\hich\af0\dbch\af0\loch\f0 enbereich\par\par\plain\rtlch\af0\afs18\alang0\acf4\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\cf4\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'dc\hich\af0\dbch\af0\loch\f0 berspannungs-Ableiter Typ 2+3\plain\rtlch\af0\afs18\alang0\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\line\plain\rtlch\af0\afs18\alang0\acf4\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\cf4\cb3\chshdng0\chcfpat0\chcbpat3 4-poliger, modularer, steckbarer\plain\rtlch\af0\afs18\alang0\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\line\plain\rtlch\af0\afs18\alang0\acf4\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\cf4\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'dc\hich\af0\dbch\af0\loch\f0 berspannungs-Ableiter mit\plain\rtlch\af0\afs18\alang0\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\line\plain\rtlch\af0\afs18\alang0\acf4\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\cf4\cb3\chshdng0\chcfpat0\chcbpat3 Doppel-Push-In-Anschlussklemme f\loch\af0\dbch\af0\hich\f0\'fc\hich\af0\dbch\af0\loch\f0 r\plain\rtlch\af0\afs18\alang0\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\line\plain\rtlch\af0\afs18\alang0\acf4\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\cf4\cb3\chshdng0\chcfpat0\chcbpat3 Stich- und Durchgangsverdrahtung,\par Breite 4TE\plain\rtlch\af0\afs18\alang0\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\line\plain\rtlch\af0\afs18\alang0\acf4\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\cf4\cb3\chshdng0\chcfpat0\chcbpat3 Ableiter Typ 2 + Typ 3 nach EN 61643-11\plain\rtlch\af0\afs18\alang0\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\line\plain\rtlch\af0\afs18\alang0\acf4\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\cf4\cb3\chshdng0\chcfpat0\chcbpat3 Defektanzeige\plain\rtlch\af0\afs18\alang0\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\line\plain\rtlch\af0\afs18\alang0\acf4\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\cf4\cb3\chshdng0\chcfpat0\chcbpat3 H\loch\af0\dbch\af0\hich\f0\'f6\hich\af0\dbch\af0\loch\f0 chste Dauerspannung: 275 V ac\plain\rtlch\af0\afs18\alang0\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\line\plain\rtlch\af0\afs18\alang0\acf4\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\cf4\cb3\chshdng0\chcfpat0\chcbpat3 Schutzpegel: <= 1,5 kV\plain\rtlch\af0\afs18\alang0\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\line\plain\rtlch\af0\afs18\alang0\acf4\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\cf4\cb3\chshdng0\chcfpat0\chcbpat3 Nennableitsto\loch\af0\dbch\af0\hich\f0\'df\hich\af0\dbch\af0\loch\f0 strom: 20 kA\plain\rtlch\af0\afs18\alang0\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\line\plain\rtlch\af0\afs18\alang0\acf4\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\cf4\cb3\chshdng0\chcfpat0\chcbpat3 Kurzschlu\loch\af0\dbch\af0\hich\f0\'df\hich\af0\dbch\af0\loch\f0 festigkeit: 50 kAeff\plain\rtlch\af0\afs18\alang0\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\line\plain\rtlch\af0\afs18\alang0\acf4\ltrch\f0\fs18\lang0\langnp0\langfe0\langfenp0\cf4\cb3\chshdng0\chcfpat0\chcbpat3 Energetische Koordination nach DIN EN 62305-4}[end]
