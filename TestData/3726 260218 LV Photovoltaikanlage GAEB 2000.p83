\headery567\footery567\pgwsxn46828\pghsxn66274\marglsxn0\margtsxn0\margrsxn0\margbsxn0\pgbrdropt32\pard\ltrpar\s17\itap0\nowidctlpar\ql\li0\ri0\lin0\rin0\plain\rtlch\af0\afs18\alang1031\ab\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\b\cf2\cb3\chshdng0\chcfpat0\chcbpat3 Potentialausgleichsschiene zum Anschluss von Leitungen, Rund- und Flachleitern. Abdeckhaube plombierbarer und beschriftbarer aus Polystyrol. UV-resistent.\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\par\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  Werkstoff: Edelstahl, rostfrei 1.4301\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  Farbe: schwarz\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  Ausf\loch\af0\dbch\af0\hich\f0\'fc\hich\af0\dbch\af0\loch\f0 hrung: mit Abdeckhaube\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  Mengeneinheit: St\loch\af0\dbch\af0\hich\f0\'fc\hich\af0\dbch\af0\loch\f0 ck\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  Dimension: 50x5mm\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  L\loch\af0\dbch\af0\hich\f0\'e4\hich\af0\dbch\af0\loch\f0 nge: 188 mm\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  Breite: 52 mm\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  H\loch\af0\dbch\af0\hich\f0\'f6\hich\af0\dbch\af0\loch\f0 he: 44,5 mm\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  Anzahl Anschluss Flachleiter bis 30 mm: 1\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  Anzahl Anschluss Leitung bis 25 mm starr: 7\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  Anzahl Anschluss Rundleiter 8-10 mm: 1\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  Anzahl Anschluss Rundleiter gesamt: 1\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  Ausf\loch\af0\dbch\af0\hich\f0\'fc\hich\af0\dbch\af0\loch\f0 hrung: mit Abdeckhaube\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  Bauform: Aufbau fix\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  Blitzstromtragf\loch\af0\dbch\af0\hich\f0\'e4\hich\af0\dbch\af0\loch\f0 higkeit: N/50 kA\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  Isolator: ja\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  Oberfl\loch\af0\dbch\af0\hich\f0\'e4\hich\af0\dbch\af0\loch\f0 che der Klemme: galvanisch verzinkt\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  Oberfl\loch\af0\dbch\af0\hich\f0\'e4\hich\af0\dbch\af0\loch\f0 che der Kontaktschiene: vernickelt\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  Werkstoff der Klemme: Stahl\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  Werkstoff der Kontaktschiene: Messing\plain\rtlch\af0\afs18\alang1031\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\line\plain\rtlch\af0\afs18\alang1031\acf2\ltrch\f0\fs18\lang1031\langnp1031\langfe1031\langfenp1031\cf2\cb3\chshdng0\chcfpat0\chcbpat3\loch\af0\dbch\af0\hich\f0\'95\hich\af0\dbch\af0\loch\f0  Anschlussm\loch\af0\dbch\af0\hich\f0\'f6\hich\af0\dbch\af0\loch\f0 glichkeiten: 1 x Flachband FL30 oder Rundleiter Rd 8 - 10, 1 x Rundleiter Rd 8 - 10 und 7 x ein- oder mehrdr\loch\af0\dbch\af0\hich\f0\'e4\hich\af0\dbch\af0\loch\f0 htige Leitungen bis 25 mm\loch\af0\dbch\af0\hich\f0\'b2\hich\af0\dbch\af0\loch\f0  oder feindr\loch\af0\dbch\af0\hich\f0\'e4\hich\af0\dbch\af0\loch\f0 htige Leitungen bis 16 mm\loch\af0\dbch\af0\hich\f0\'b2}[end]
