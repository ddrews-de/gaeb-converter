    <Item ID="RIU0EI3G000003" RNoPart="01010010">
     <Qty>16239.7</Qty>
     <QU>m²/a</QU>
     <Description>
      <CompleteText>
        <OutlineText>
         <TextOutlTxt>
          <p>
           <span>V1a.2   Büro (Textilbeläge) - UR</span>
          </p>
         </TextOutlTxt>
        </OutlineText>
        <DetailTxt>
         <Text>
          <p>
           <span>Leistung:</span>
          </p>
          <p>
           <span>-   Textilbeläge (Nadelfilz oder Teppich) saugen.</span>
          </p>
          <p>
           <span>-   Fleckenentfernung, soweit erforderlich, von bis zu</span>
          </p>
          <p>
           <span>3 Flecken (a &lt; 1 dm²) je Reinigungsgang.</span>
          </p>
          <p>
           <span>-   Horizontale Flächen des Einrichtungsmobiliars</span>
          </p>
          <p>
           <span>(inkl. Tische, Halbschränke) und Fensterbänke, bis</span>
          </p>
          <p>
           <span>1,80 m, soweit freigeräumt, feucht reinigen.</span>
          </p>
          <p>
           <span>-   Griffspuren und sichtbare Verschmutzungen an Türen</span>
          </p>
          <p>
           <span>und Glastüren sowie an Rahmen, Griffen, Beschlägen und</span>
          </p>
          <p>
           <span>Lichtschaltern entfernen.</span>
          </p>
          <p>
           <span>-   Abfallbehälter entleeren (Inhalt an den</span>
          </p>
          <p>
           <span>entsprechenden Sammelstellen entsorgen) und mit</span>
          </p>
          <p>
           <span>entsprechenden Beuteln bestücken.</span>
          </p>
          <p>
           <span>-   Papierkörbe (i.d.R. 1-2 Stück je Büro) leeren und</span>
          </p>
          <p>
           <span>den Inhalt an entsprechender Sammelstelle entsorgen.</span>
          </p>
          <p>
           <span>-   Spinnweben entfernen.</span>
          </p>
          <p>
           <span>Leistungskenngrößen:</span>
          </p>
          <p>
           <span>Flächenart:   NF 2.1, 2.2</span>
          </p>
          <p>
           <span>einfache Fläche:   64,70 m²</span>
          </p>
          <p>
           <span>Reinigungszyklus:   251 / Jahr</span>
          </p>
         </Text>
        </DetailTxt>
      </CompleteText>
     </Description>
    </Item>
