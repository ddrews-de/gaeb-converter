    <Item ID="RIU0EI3G00001E" RNoPart="01050010">
     <Description>
      <CompleteText>
        <OutlineText>
         <TextOutlTxt>
          <p>
           <span>Reinigungskraft für Unterhaltsreinigung</span>
          </p>
         </TextOutlTxt>
        </OutlineText>
        <DetailTxt>
         <Text>
          <p>
           <span>Ausführung von zusätzlichen Reinigungsleistungen der</span>
          </p>
          <p>
           <span>Unterhaltsreinigung (Lohngruppe 1); z.B.</span>
          </p>
          <p>
           <span>desinfizierende Reinigung im Bereich der Zellen</span>
          </p>
          <p>
           <span>Bei Erfordernis erfolgt die Abrechnung auf das</span>
          </p>
          <p>
           <span>betroffene Haus gemäß</span>
          </p>
          <p>
           <span>Stundenverrechnungssatz werktags je angefangene halbe</span>
          </p>
          <p>
           <span>Stunde:</span>
          </p>
          <p>
           <span>61B                SVS    _/h &apos;</span>
          </p>
          <p>
           <span>61B</span>
          </p>
          <p>
           <span>61B....................................................&apos;</span>
          </p>
          <p>
           <span>Für den Fall, dass die zusätzlichen Leistungen an</span>
          </p>
          <p>
           <span>Sonntagen, Feiertagen oder Nachts erfolgen sollen,</span>
          </p>
          <p>
           <span>gelten die tariflichen Zuschläge zuzüglich zum</span>
          </p>
          <p>
           <span>Stundenverrechnungssatz.</span>
          </p>
          <p>
           <span>Zuschlag für Nachtarbeit (22:00 - 05:00 Uhr):   je</span>
          </p>
          <p>
           <span>62BStunde  % &apos;</span>
          </p>
          <p>
           <span>62B</span>
          </p>
          <p>
           <span>62B....................................................&apos;</span>
          </p>
          <p>
           <span>Bei Erfordernis erfoldt die Abrechnung auf das</span>
          </p>
          <p>
           <span>betroffene Haus.</span>
          </p>
          <p>
           <span>63BZuschlag für Sonntage:      je Stunde % &apos;</span>
          </p>
          <p>
           <span>63B</span>
          </p>
          <p>
           <span>63B....................................................&apos;</span>
          </p>
          <p>
           <span>Bei Erfordernis erfoldt die Abrechnung auf das</span>
          </p>
          <p>
           <span>betroffene Haus.</span>
          </p>
          <p>
           <span>64BZuschlag für Feiertage:      je Stunde % &apos;</span>
          </p>
          <p>
           <span>64B</span>
          </p>
          <p>
           <span>64B....................................................&apos;</span>
          </p>
          <p>
           <span>Bei Erfordernis erfoldt die Abrechnung auf das</span>
          </p>
          <p>
           <span>betroffene Haus.</span>
          </p>
          <p>
           <span>Die Leistung erfolgt auf gesonderte Anforderung des</span>
          </p>
          <p>
           <span>Auftraggebers.</span>
          </p>
          <p>
           <span>Ein Arbeitsschein ist vorzulegen.</span>
          </p>
         </Text>
        </DetailTxt>
      </CompleteText>
     </Description>
    </Item>
