          <p>
           <span>Zelle2 = 8,00m²,</span>
          </p>
          <p>
           <span>      Zelle3 = 8,00m², Zelle4 = 8,00m², Zelle5 =</span>
          </p>
          <p>
           <span>23,00m²</span>
          </p>
