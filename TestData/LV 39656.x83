    <Item ID="RIU0EI3G000006" RNoPart="01010040">
     <Qty>8200.17</Qty>
     <QU>m²/a</QU>
     <Description>
      <CompleteText>
        <OutlineText>
         <TextOutlTxt>
          <p>
           <span>V3b   Aufenthalt 12 - UR</span>
          </p>
         </TextOutlTxt>
        </OutlineText>
        <DetailTxt>
         <Text>
          <p>
           <span>Leistung:</span>
          </p>
          <p>
           <span>-   Boden (PVC, Fliesen und sonstige Hartbelagböden)</span>
          </p>
          <p>
           <span>zweistufig nass wischen</span>
          </p>
          <p>
           <span>-   Griffspuren und sichtbare Verschmutzungen an Türen,</span>
          </p>
          <p>
           <span>Schränken, Griffen, Beschlägen und Lichtschaltern</span>
          </p>
          <p>
           <span>entfernen.</span>
          </p>
          <p>
           <span>-   Horizontale Flächen des Einrichtungsmobiliars</span>
          </p>
          <p>
           <span>(inkl. Tische, Halbschränke) und Fensterbänke, bis</span>
          </p>
          <p>
           <span>1,80 m, soweit freigeräumt, feucht reinigen.</span>
          </p>
          <p>
           <span>-   Abfallbehälter, Papierkörbe entleeren, Inhalt an</span>
          </p>
          <p>
           <span>den entsprechenden Sammelstellen entsorgen, bei Bedarf</span>
          </p>
          <p>
           <span>innen und außen nass reinigen und nachtrocknen sowie</span>
          </p>
          <p>
           <span>mit entsprechenden Beuteln bestücken.</span>
          </p>
          <p>
           <span>-   Küchenabfallbehälter (Biomüll) entleeren und den</span>
          </p>
          <p>
           <span>Inhalt an entsprechenden Sammelstellen entsorgen, innen</span>
          </p>
          <p>
           <span>und außen nass reinigen und nachtrocknen sowie mit</span>
          </p>
          <p>
           <span>entsprechenden Beuteln bestücken.</span>
          </p>
          <p>
           <span>-   Wasch- bzw. Ausgussbecken inkl. Ablage, Armaturen</span>
          </p>
          <p>
           <span>und Fliesenspiegel vollflächig nass reinigen und</span>
          </p>
          <p>
           <span>nachtrocknen; für den Fall, dass diese aus Edelstahl</span>
          </p>
          <p>
           <span>bestehen, ist ein Edelstahlreinigungsmittel zu</span>
          </p>
          <p>
           <span>verwenden.</span>
          </p>
          <p>
           <span>-   Spritzer im Spritzbereich (Wandfliesen, Trennwände,</span>
          </p>
          <p>
           <span>etc.) entfernen.</span>
          </p>
          <p>
           <span>-   Kalk-, Wasserstein und andere Rückstände an</span>
          </p>
          <p>
           <span>Armaturen und in Waschbecken entfernen.</span>
          </p>
          <p>
           <span>-   Spinnweben entfernen.</span>
          </p>
          <p>
           <span>Leistungskenngrößen:</span>
          </p>
          <p>
           <span>Flächenart:   NF 3.8</span>
          </p>
          <p>
           <span>einfache Fläche:   32,67 m²</span>
          </p>
          <p>
           <span>Reinigungszyklus:   251 / Jahr</span>
          </p>
         </Text>
        </DetailTxt>
      </CompleteText>
     </Description>
    </Item>
    <Item ID="RIU0EI3G000007" RNoPart="01010050">
     <Qty>5705.23</Qty>
     <QU>m²/a</QU>
     <Description>
      <CompleteText>
        <OutlineText>
         <TextOutlTxt>
          <p>
           <span>V4   Sonstige 01 - UR</span>
          </p>
         </TextOutlTxt>
        </OutlineText>
        <DetailTxt>
         <Text>
          <p>
           <span>Leistung:</span>
          </p>
          <p>
           <span>-   Boden (Fliesen und sonstige Hartbelagböden)</span>
          </p>
          <p>
           <span>zweistufig nass wischen; Sicherheitsfliesen ggf.</span>
          </p>
          <p>
           <span>aufscheuern.</span>
          </p>
          <p>
           <span>-   Griffspuren und sichtbare Verschmutzungen an Türen</span>
          </p>
          <p>
           <span>und Glastüren sowie an Rahmen, Griffen, Beschlägen und</span>
          </p>
          <p>
           <span>Lichtschaltern, Fensterbänke entfernen.</span>
          </p>
          <p>
           <span>-   Abfallbehälter entleeren (Inhalt an den</span>
          </p>
          <p>
           <span>entsprechenden Sammelstellen entsorgen) und mit</span>
          </p>
          <p>
           <span>entsprechenden Beuteln bestücken.</span>
          </p>
          <p>
           <span>-   Wasch- bzw. Ausgussbecken inkl. Spiegel, Ablagen,</span>
          </p>
          <p>
           <span>Spender von Verbrauchs- und Hygieneartikeln, Armaturen</span>
          </p>
          <p>
           <span>und Fliesenspiegel vollflächig nass reinigen und</span>
          </p>
          <p>
           <span>nachtrocknen; für den Fall, dass diese aus Edelstahl</span>
          </p>
          <p>
           <span>bestehen, ist ein Edelstahlreinigungsmittel zu</span>
          </p>
          <p>
           <span>verwenden.</span>
          </p>
          <p>
           <span>-   Bestückung mit Verbrauchs- und Hygieneartikeln.</span>
          </p>
          <p>
           <span>-   WC-Becken inkl. WC-Sitz und Abdeckung vollflächig</span>
          </p>
          <p>
           <span>von oben und unten desinfizierend nass reinigen und</span>
          </p>
          <p>
           <span>nachtrocknen.</span>
          </p>
          <p>
           <span>-   Urinalbecken vollflächig desinfizierend nass</span>
          </p>
          <p>
           <span>reinigen und nachtrocknen.</span>
          </p>
          <p>
           <span>-   ggf. Kalk-, Wasser-, Urinstein und andere</span>
          </p>
          <p>
           <span>Rückstände entfernen.</span>
          </p>
          <p>
           <span>-   Wandfliesen, Trennwände im Spritzbereich nass</span>
          </p>
          <p>
           <span>reinigen und nachtrocknen.</span>
          </p>
          <p>
           <span>-   Spinnweben entfernen</span>
          </p>
          <p>
           <span>Leistungskenngrößen:</span>
          </p>
          <p>
           <span>Flächenart:   NF 7.1</span>
          </p>
          <p>
           <span>einfache Fläche:   22,73 m²</span>
          </p>
          <p>
           <span>Reinigungszyklus:   251 / Jahr</span>
          </p>
         </Text>
        </DetailTxt>
      </CompleteText>
     </Description>
    </Item>
    <Item ID="RIU0EI3G000008" RNoPart="01010060">
     <Qty>6924.32</Qty>
     <QU>m²/a</QU>
     <Description>
      <CompleteText>
        <OutlineText>
         <TextOutlTxt>
          <p>
           <span>V6b   Flure (Hartbelagboden) - UR</span>
          </p>
         </TextOutlTxt>
        </OutlineText>
        <DetailTxt>
         <Text>
          <p>
           <span>Leistung:</span>
          </p>
          <p>
           <span>-   Boden (PVC und sonstige Hartbelagböden) einstufig</span>
          </p>
          <p>
           <span>nass wischen.</span>
          </p>
          <p>
           <span>-   Griffspuren und sichtbare Verschmutzungen an Türen,</span>
          </p>
          <p>
           <span>Glastüren und sonstigen inneren Glasflächen sowie an</span>
          </p>
          <p>
           <span>Rahmen, Griffen, Gittern,  Beschlägen und</span>
          </p>
          <p>
           <span>Lichtschaltern entfernen.</span>
          </p>
          <p>
           <span>-   Griffspuren an Schaltplatten, Rufanlagen, autom.</span>
          </p>
          <p>
           <span>Türöffnern durch feuchtes Reinigen entfernen.</span>
          </p>
          <p>
           <span>-   Horizontale Flächen des Einrichtungsmobiliars</span>
          </p>
          <p>
           <span>(inkl. Tische) bis 1,80 m, Fensterbänke, soweit</span>
          </p>
          <p>
           <span>freigeräumt, feucht reinigen.</span>
          </p>
          <p>
           <span>-   Feuerlöscher monatlich vorsichtig feucht abwischen.</span>
          </p>
          <p>
           <span>-   Abfallbehälter entleeren (Inhalt in Behältnisse an</span>
          </p>
          <p>
           <span>den entsprechenden Sammelstellen entsorgen).</span>
          </p>
          <p>
           <span>-   Spinnweben entfernen.</span>
          </p>
          <p>
           <span>-   Rauchschutztüren 1xmonatlich zweiseitig reinigen.</span>
          </p>
          <p>
           <span>Leistungskenngrößen:</span>
          </p>
          <p>
           <span>Flächenart:   VF 9.1</span>
          </p>
          <p>
           <span>einfache Fläche:   66,58 m²</span>
          </p>
          <p>
           <span>Reinigungszyklus:   104 / Jahr</span>
          </p>
         </Text>
        </DetailTxt>
      </CompleteText>
     </Description>
    </Item>
