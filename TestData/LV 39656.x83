    <Item ID="RIU0EI3G00000A" RNoPart="01010080">
     <Qty>8288.02</Qty>
     <QU>m²/a</QU>
     <Description>
      <CompleteText>
        <OutlineText>
         <TextOutlTxt>
          <p>
           <span>V10a   Sonstige 02 - UR</span>
          </p>
         </TextOutlTxt>
        </OutlineText>
        <DetailTxt>
         <Text>
          <p>
           <span>Leistung:</span>
          </p>
          <p>
           <span>-   Textilbeläge (Nadelfilz oder Teppich) saugen.</span>
          </p>
          <p>
           <span>-   Griffspuren und sichtbare Verschmutzungen an Türen</span>
          </p>
          <p>
           <span>und Glastüren (Innen- und Außenglas) sowie an sonstigen</span>
          </p>
          <p>
           <span>inneren Glasflächen, Rahmen, Griffen, Beschlägen und</span>
          </p>
          <p>
           <span>Lichtschaltern entfernen.</span>
          </p>
          <p>
           <span>-   Horizontale Flächen des Einrichtungsmobiliars</span>
          </p>
          <p>
           <span>(inkl. Tische) und Fensterbänke, bis 1,80 m, soweit</span>
          </p>
          <p>
           <span>freigeräumt, feucht reinigen.</span>
          </p>
          <p>
           <span>-   Abfallbehälter entleeren (Inhalt an den</span>
          </p>
          <p>
           <span>entsprechenden Sammelstellen entsorgen).</span>
          </p>
          <p>
           <span>-   Handlauf feucht reinigen.</span>
          </p>
          <p>
           <span>-   Verschmutzung auf Fußmatten entfernen und den Boden</span>
          </p>
          <p>
           <span>darunter saugen.</span>
          </p>
          <p>
           <span>-   Aschenbecher an den dafür vorgesehenen Stellen</span>
          </p>
          <p>
           <span>entleeren und den Aschenbecher feucht reinigen.</span>
          </p>
          <p>
           <span>-   Raucherinseln im Außenbereich: Entleerung von</span>
